---
// Newsletter subscription form powered by Brevo
import { useTranslations, type Locale } from '../i18n';

interface Props {
	locale?: Locale;
}

const { locale = 'fr' } = Astro.props;
const t = useTranslations(locale);
---

<div class="newsletter-section">
	<div class="newsletter-container">
		<div class="newsletter-header">
			<h3>{t.newsletter.title}</h3>
			<p>{t.newsletter.description}</p>
		</div>

		<div id="sib-form-container" class="sib-form-container">
			<div id="error-message" class="sib-form-message-panel sib-form-message-panel--error">
				<div class="sib-form-message-panel__text">
					<svg viewBox="0 0 512 512" class="sib-icon">
						<path d="M256 40c118.621 0 216 96.075 216 216 0 119.291-96.61 216-216 216-119.244 0-216-96.562-216-216 0-119.203 96.602-216 216-216m0-32C119.043 8 8 119.083 8 256c0 136.997 111.043 248 248 248s248-111.003 248-248C504 119.083 392.957 8 256 8zm-11.49 120h22.979c6.823 0 12.274 5.682 11.99 12.5l-7 168c-.268 6.428-5.556 11.5-11.99 11.5h-8.979c-6.433 0-11.722-5.073-11.99-11.5l-7-168c-.283-6.818 5.167-12.5 11.99-12.5zM256 340c-15.464 0-28 12.536-28 28s12.536 28 28 28 28-12.536 28-28-12.536-28-28-28z" />
					</svg>
					<span>{t.newsletter.errorMessage}</span>
				</div>
			</div>

			<div id="success-message" class="sib-form-message-panel sib-form-message-panel--success">
				<div class="sib-form-message-panel__text">
					<svg viewBox="0 0 512 512" class="sib-icon">
						<path d="M256 8C119.033 8 8 119.033 8 256s111.033 248 248 248 248-111.033 248-248S392.967 8 256 8zm0 464c-118.664 0-216-96.055-216-216 0-118.663 96.055-216 216-216 118.664 0 216 96.055 216 216 0 118.663-96.055 216-216 216zm141.63-274.961L217.15 376.071c-4.705 4.667-12.303 4.637-16.97-.068l-85.878-86.572c-4.667-4.705-4.637-12.303.068-16.97l8.52-8.451c4.705-4.667 12.303-4.637 16.97.068l68.976 69.533 163.441-162.13c4.705-4.667 12.303-4.637 16.97.068l8.451 8.52c4.668 4.705 4.637 12.303-.068 16.97z" />
					</svg>
					<span>{t.newsletter.successMessage}</span>
				</div>
			</div>

			<form
				id="sib-form"
				method="POST"
				action="=>BREVO_FORM_URL="
				data-type="subscription"
			>
				<div class="form-group">
					<input
						class="email-input"
						type="email"
						id="EMAIL"
						name="EMAIL"
						autocomplete="email"
						placeholder={t.newsletter.emailPlaceholder}
						data-required="true"
						required
					/>
					<button class="submit-btn" type="submit">
						<svg class="icon progress-indicator__icon sib-hide-loader-icon" viewBox="0 0 512 512">
							<path d="M460.116 373.846l-20.823-12.022c-5.541-3.199-7.54-10.159-4.663-15.874 30.137-59.886 28.343-131.652-5.386-189.946-33.641-58.394-94.896-95.833-161.827-99.676C261.028 55.961 256 50.751 256 44.352V20.309c0-6.904 5.808-12.337 12.703-11.982 83.556 4.306 160.163 50.864 202.11 123.677 42.063 72.696 44.079 162.316 6.031 236.832-3.14 6.148-10.75 8.461-16.728 5.01z" />
						</svg>
						{t.newsletter.submitButton}
					</button>
				</div>

				<label class="entry__error entry__error--primary"></label>

				<p class="disclaimer">
					{t.newsletter.disclaimer}
				</p>

				<input type="text" name="email_address_check" value="" class="input--hidden">
				<input type="hidden" name="locale" value="fr">
			</form>
		</div>
	</div>
</div>

<script is:inline>
	window.REQUIRED_CODE_ERROR_MESSAGE = 'Veuillez choisir un code pays';
	window.LOCALE = 'fr';
	window.EMAIL_INVALID_MESSAGE = window.SMS_INVALID_MESSAGE = "Les informations que vous avez fournies ne sont pas valides. Veuillez vérifier le format du champ et réessayer.";
	window.REQUIRED_ERROR_MESSAGE = "Vous devez renseigner ce champ.";
	window.GENERIC_INVALID_MESSAGE = "Les informations que vous avez fournies ne sont pas valides. Veuillez vérifier le format du champ et réessayer.";
	window.translation = {
		common: {
			selectedList: '{quantity} liste sélectionnée',
			selectedLists: '{quantity} listes sélectionnées',
			selectedOption: '{quantity} sélectionné',
			selectedOptions: '{quantity} sélectionnés',
		}
	};
	var AUTOHIDE = Boolean(0);
</script>

<script defer src="https://sibforms.com/forms/end-form/build/main.js"></script>

<style>
	.newsletter-section {
		width: 100%;
		padding: 3rem 2rem;
		background: var(--gray-200);
		border-top: 1px solid var(--gray-300);
		border-bottom: 1px solid var(--gray-300);
	}

	.newsletter-container {
		max-width: 700px;
		margin: 0 auto;
	}

	.newsletter-header {
		text-align: center;
		margin-bottom: 1.5rem;
	}

	.newsletter-header h3 {
		font-size: var(--text-xl);
		color: var(--gray-200);
		margin: 0 0 0.5rem 0;
		font-weight: 600;
	}

	.newsletter-header p {
		font-size: var(--text-sm);
		color: var(--gray-400);
		margin: 0;
	}

	.sib-form-container {
		width: 100%;
	}

	.sib-form-message-panel {
		display: none;
		padding: 1rem;
		border-radius: 8px;
		margin-bottom: 1rem;
		font-size: var(--text-sm);
	}

	.sib-form-message-panel.sib-form-message-panel--active {
		display: block;
	}

	.sib-form-message-panel--error {
		background-color: rgba(255, 77, 73, 0.1);
		border: 1px solid rgba(255, 77, 73, 0.3);
		color: #ff4d49;
	}

	.sib-form-message-panel--success {
		background-color: rgba(19, 206, 102, 0.1);
		border: 1px solid rgba(19, 206, 102, 0.3);
		color: #13ce66;
	}

	.sib-form-message-panel__text {
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}

	.sib-icon {
		width: 20px;
		height: 20px;
		flex-shrink: 0;
		fill: currentColor;
	}

	.form-group {
		display: flex;
		gap: 0.5rem;
		margin-bottom: 0.75rem;
	}

	.email-input {
		flex: 1;
		padding: 0.75rem 1rem;
		background: var(--gray-999);
		border: 1px solid var(--gray-700);
		border-radius: 8px;
		color: var(--gray-0);
		font-size: var(--text-sm);
		transition: all 0.2s ease;
	}

	.email-input:focus {
		outline: none;
		border-color: var(--accent-regular);
		box-shadow: 0 0 0 3px var(--accent-overlay);
	}

	.email-input::placeholder {
		color: var(--gray-400);
	}

	.submit-btn {
		padding: 0.75rem 1.5rem;
		background: var(--gradient-accent);
		color: var(--gray-999);
		border: none;
		border-radius: 8px;
		font-size: var(--text-sm);
		font-weight: 600;
		cursor: pointer;
		transition: all 0.2s ease;
		display: flex;
		align-items: center;
		gap: 0.5rem;
		white-space: nowrap;
	}

	.submit-btn:hover {
		transform: translateY(-2px);
		box-shadow: 0 4px 12px var(--accent-overlay);
	}

	.submit-btn:active {
		transform: translateY(0);
	}

	.progress-indicator__icon {
		width: 16px;
		height: 16px;
		fill: currentColor;
	}

	.sib-hide-loader-icon {
		display: none;
	}

	.submit-btn.sib-form-block__button-with-loader .progress-indicator__icon {
		animation: spin 1s linear infinite;
	}

	@keyframes spin {
		from { transform: rotate(0deg); }
		to { transform: rotate(360deg); }
	}

	.entry__error {
		display: none;
		color: #ff4d49;
		font-size: var(--text-xs);
		margin-top: 0.25rem;
	}

	.entry__error--primary {
		display: block;
	}

	.disclaimer {
		font-size: var(--text-xs);
		color: var(--gray-500);
		text-align: center;
		font-style: italic;
		margin: 0;
	}

	.input--hidden {
		position: absolute;
		left: -5000px;
		height: 0;
		width: 0;
	}

	/* Responsive */
	@media (max-width: 50em) {
		.newsletter-section {
			padding: 1.5rem 0;
		}

		.form-group {
			flex-direction: column;
		}

		.submit-btn {
			width: 100%;
			justify-content: center;
		}
	}

	/* Dark theme adjustments */
	:global(.theme-dark) .newsletter-section {
		background: var(--gray-0);
		border-top-color: var(--gray-200);
		border-bottom-color: var(--gray-200);
	}

	:global(.theme-dark) .email-input {
		background: var(--gray-100);
		border-color: var(--gray-300);
		color: var(--gray-999);
	}

	:global(.theme-dark) .email-input:focus {
		border-color: var(--accent-light);
	}

	:global(.theme-dark) .newsletter-header h3 {
		color: var(--gray-800);
	}
</style>
