---
// Newsletter subscription form powered by Brevo
import { useTranslations, type Locale } from '../i18n';

interface Props {
	locale?: Locale;
}

const { locale = 'fr' } = Astro.props;
const t = useTranslations(locale);
---

<div class="newsletter-section">
	<div class="newsletter-container">
		<h2>{t.newsletter.title}</h2>
		<p class="newsletter-description">{t.newsletter.description}</p>

		<form
			id="newsletter-form"
			action="=>BREVO_FORM_URL="
			method="POST"
			class="newsletter-form"
		>
			{/* Honeypot : champ invisible pour les humains, rempli par les bots */}
			<div style="position:absolute;left:-9999px;top:-9999px;" aria-hidden="true">
				<input type="text" name="website" id="newsletter-honeypot" tabindex="-1" autocomplete="off" />
			</div>
			<div id="form-content">
				<label class="robot-check">
					<span class="robot-checkbox-wrapper">
						<input type="checkbox" id="not-a-robot" />
						<span class="robot-checkmark"></span>
					</span>
					<span class="robot-label">Je ne suis pas un robot</span>
				</label>
				<div class="form-group">
					<input
						type="email"
						name="EMAIL"
						id="newsletter-email"
						placeholder={t.newsletter.emailPlaceholder}
						required
						disabled
						class="newsletter-input"
					/>
					<button type="submit" disabled class="newsletter-button">
						{t.newsletter.submitButton}
					</button>
				</div>
				<p class="newsletter-disclaimer">{t.newsletter.disclaimer}</p>
			</div>
			<div id="success-message" class="message success-message" style="display: none;">
				<p>{t.newsletter.successMessage}</p>
			</div>
			<div id="error-message" class="message error-message" style="display: none;">
				<p>{t.newsletter.errorMessage}</p>
			</div>
		</form>
	</div>
</div>

<script>
	document.addEventListener('DOMContentLoaded', function() {
		var form = document.getElementById('newsletter-form');
		var formContent = document.getElementById('form-content');
		var successMessage = document.getElementById('success-message');
		var errorMessage = document.getElementById('error-message');
		var loadedAt = Date.now();

		var robotCheck = document.getElementById('not-a-robot');
		var emailInput = document.getElementById('newsletter-email');
		var submitButton = form ? form.querySelector('.newsletter-button') : null;

		if (robotCheck) {
			robotCheck.addEventListener('change', function() {
				if (!robotCheck.checked) {
					emailInput && (emailInput.disabled = true);
					submitButton && (submitButton.disabled = true);
					robotCheck.closest('.robot-check').classList.remove('robot-check--active', 'robot-check--loading');
					return;
				}

				// Empêche de re-cliquer pendant la vérification
				robotCheck.disabled = true;
				var label = robotCheck.closest('.robot-check');
				label.classList.add('robot-check--loading');
				label.classList.remove('robot-check--error');

				setTimeout(function() {
					robotCheck.disabled = false;
					label.classList.remove('robot-check--loading');
					label.classList.add('robot-check--active');
					emailInput && (emailInput.disabled = false);
					submitButton && (submitButton.disabled = false);
					emailInput && emailInput.focus();
				}, 1500);
			});
		}

		if (form) {
			form.addEventListener('submit', function(e) {
				e.preventDefault();

				// Anti-bot : honeypot
				var honeypot = document.getElementById('newsletter-honeypot');
				if (honeypot && honeypot.value !== '') return;

				// Anti-bot : délai minimum
				if (Date.now() - loadedAt < 10000) return;

				// Anti-bot : checkbox obligatoire
				var robotCheck = document.getElementById('not-a-robot');
				if (!robotCheck || !robotCheck.checked) {
					robotCheck && robotCheck.closest('.robot-check').classList.add('robot-check--error');
					return;
				}

				var email = document.getElementById('newsletter-email').value;
				var formData = new FormData();
				formData.append('EMAIL', email);

				fetch(form.action, {
					method: 'POST',
					body: formData,
					mode: 'no-cors'
				})
				.then(function() {
					formContent.style.display = 'none';
					successMessage.style.display = 'block';
					errorMessage.style.display = 'none';
				})
				.catch(function() {
					formContent.style.display = 'none';
					successMessage.style.display = 'none';
					errorMessage.style.display = 'block';
				});
			});
		}
	});
</script>

<style>
	.newsletter-section {
		width: 100%;
		padding: 5rem 2rem;
		background: var(--gradient-subtle);
		display: flex;
		justify-content: center;
		margin-top: 3rem;
	}

	.newsletter-container {
		width: 100%;
		max-width: 600px;
		text-align: center;
	}

	.newsletter-container h2 {
		font-size: var(--text-3xl);
		color: var(--gray-100);
		margin-bottom: 1rem;
	}

	.newsletter-description {
		font-size: var(--text-md);
		color: var(--gray-400);
		margin-bottom: 2rem;
		line-height: 1.6;
	}

	.newsletter-form {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.form-group {
		display: flex;
		gap: 0.75rem;
		flex-direction: column;
	}

	.newsletter-input {
		flex: 1;
		padding: 1rem 1.5rem;
		font-size: var(--text-base);
		border: 2px solid var(--gray-700);
		border-radius: 0.5rem;
		background: var(--gray-999);
		color: var(--gray-200);
		transition: all 0.3s ease;
		font-family: var(--font-body);
	}

	.newsletter-input:disabled,
	.newsletter-button:disabled {
		opacity: 0.4;
		cursor: not-allowed;
	}

	.newsletter-button:disabled:hover {
		transform: none;
		box-shadow: none;
		background: var(--accent-regular);
	}

	.newsletter-input:focus {
		outline: none;
		border-color: var(--accent-regular);
		box-shadow: 0 0 0 3px var(--accent-overlay);
	}

	.newsletter-input::placeholder {
		color: var(--gray-500);
	}

	.newsletter-button {
		padding: 1rem 2rem;
		font-size: var(--text-base);
		font-weight: 600;
		background: var(--accent-regular);
		color: var(--accent-text-over);
		border: none;
		border-radius: 0.5rem;
		cursor: pointer;
		transition: all 0.3s ease;
		font-family: var(--font-body);
	}

	.newsletter-button:hover {
		background: var(--accent-dark);
		transform: translateY(-2px);
		box-shadow: 0 4px 12px var(--accent-overlay);
	}

	.robot-check {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		background: var(--gray-900, #1a1a2e);
		border: 2px solid var(--gray-700, #374151);
		border-radius: 0.5rem;
		padding: 0.875rem 1.25rem;
		cursor: pointer;
		user-select: none;
		transition: border-color 0.2s ease;
	}

	.robot-check:hover {
		border-color: var(--gray-500, #6b7280);
	}

	.robot-check--error {
		border-color: #f87171;
		animation: shake 0.3s ease;
	}

	.robot-check--loading {
		cursor: wait;
	}

	.robot-check--loading .robot-checkmark {
		border-color: transparent;
		border-top-color: var(--accent-regular, #7c3aed);
		animation: spin 0.8s linear infinite;
	}

	@keyframes spin {
		to { transform: rotate(360deg); }
	}

	@keyframes shake {
		0%, 100% { transform: translateX(0); }
		25% { transform: translateX(-6px); }
		75% { transform: translateX(6px); }
	}

	.robot-checkbox-wrapper {
		position: relative;
		width: 22px;
		height: 22px;
		flex-shrink: 0;
	}

	.robot-checkbox-wrapper input[type="checkbox"] {
		position: absolute;
		opacity: 0;
		width: 100%;
		height: 100%;
		cursor: pointer;
		margin: 0;
	}

	.robot-checkmark {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 22px;
		height: 22px;
		border: 2px solid var(--gray-600, #4b5563);
		border-radius: 4px;
		background: var(--gray-999, #0a0a0f);
		transition: all 0.2s ease;
	}

	.robot-checkbox-wrapper input:checked ~ .robot-checkmark {
		background: var(--accent-regular, #7c3aed);
		border-color: var(--accent-regular, #7c3aed);
	}

	.robot-checkbox-wrapper input:checked ~ .robot-checkmark::after {
		content: '';
		display: block;
		width: 5px;
		height: 10px;
		border: 2px solid white;
		border-top: none;
		border-left: none;
		transform: rotate(45deg) translateY(-2px);
	}

	.robot-label {
		font-size: var(--text-sm);
		color: var(--gray-300, #d1d5db);
	}

	.newsletter-disclaimer {
		font-size: var(--text-sm);
		color: var(--gray-500);
		line-height: 1.5;
	}

	.message {
		padding: 1.5rem;
		border-radius: 0.5rem;
		text-align: center;
		font-size: var(--text-md);
	}

	.success-message {
		background: linear-gradient(135deg, #f0fdf4 0%, #dcfce7 100%);
		border: 2px solid #4ade80;
		color: #15803d;
	}

	.error-message {
		background: linear-gradient(135deg, #fef2f2 0%, #fee2e2 100%);
		border: 2px solid #f87171;
		color: #dc2626;
	}

	.message p {
		margin: 0;
		font-weight: 600;
	}

	/* Responsive */
	@media (min-width: 50em) {
		.form-group {
			flex-direction: row;
		}

		.newsletter-button {
			padding: 1rem 2.5rem;
			white-space: nowrap;
		}
	}

	@media (max-width: 50em) {
		.newsletter-section {
			padding: 3rem 1rem;
			margin-top: 2rem;
		}

		.newsletter-container h2 {
			font-size: var(--text-2xl);
		}
	}

	/* Dark theme adjustments */
	:global(.theme-dark) .newsletter-input {
		background: var(--gray-900);
		border-color: var(--gray-600);
	}

	:global(.theme-dark) .newsletter-input:focus {
		border-color: var(--accent-light);
	}

	:global(.theme-dark) .success-message {
		background: linear-gradient(135deg, #064e3b 0%, #065f46 100%);
		border-color: #10b981;
		color: #6ee7b7;
	}

	:global(.theme-dark) .error-message {
		background: linear-gradient(135deg, #7f1d1d 0%, #991b1b 100%);
		border-color: #ef4444;
		color: #fca5a5;
	}
</style>
