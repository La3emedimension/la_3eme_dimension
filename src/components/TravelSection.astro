---
interface Props {
	title: string;
	description?: string;
	image?: { src: string; alt: string };
}

const { title, description, image } = Astro.props;
---

<section class="travel-section">
	<div class="wrapper stack gap-8">
		<div class="travel-header">
			<h2>{title}</h2>
			{description && <p class="description">{description}</p>}
		</div>

		<div class="travel-content">
			{image ? (
				<div class="image-container">
					<img src={image.src} alt={image.alt} class="travel-image" />
				</div>
			) : (
				<div class="media-placeholder">
					<p>Photos et vidéos à venir</p>
				</div>
			)}
		</div>
	</div>
</section>

<style>
	.travel-section {
		padding: 4rem 0;
		background: var(--gradient-subtle);
	}

	.travel-header {
		text-align: center;
		max-width: 50rem;
		margin: 0 auto;
	}

	.travel-header h2 {
		font-size: var(--text-3xl);
		font-weight: 700;
		color: var(--gray-0);
		margin-bottom: 1rem;
	}

	.description {
		font-size: var(--text-lg);
		color: var(--gray-300);
		line-height: 1.6;
	}

	.travel-content {
		margin-top: 2rem;
	}

	.image-container {
		display: flex;
		justify-content: center;
	}

	.travel-image {
		max-width: 600px;
		width: 100%;
		border-radius: 1rem;
		box-shadow: var(--shadow-lg);
	}

	.media-placeholder {
		background: var(--gray-900);
		border: 2px dashed var(--gray-700);
		border-radius: 1rem;
		padding: 4rem 2rem;
		text-align: center;
		color: var(--gray-400);
	}

	@media (max-width: 50em) {
		.travel-section {
			padding: 3rem 0;
		}

		.travel-header h2 {
			font-size: var(--text-2xl);
		}

		.description {
			font-size: var(--text-base);
		}
	}
</style>
