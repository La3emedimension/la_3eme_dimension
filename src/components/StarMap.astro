// ─── Math helpers
function mod360(x: number) { return ((x % 360) + 360) % 360; }
function rad(x: number) { return x * Math.PI / 180; }
function deg(x: number) { return x * 180 / Math.PI; }

function julianDate(date: Date) {
  return date.getTime() / 86400000 + 2440587.5;
}

function gmstDeg(jd: number) {
  const T = (jd - 2451545.0) / 36525;
  return mod360(280.46061837 + 360.98564736629 * (jd - 2451545.0) + 0.000387933 * T * T - T * T * T / 38710000);
}

function toAltAz(raDeg: number, decDeg: number, lat: number, lon: number, jd: number) {
  const lst = mod360(gmstDeg(jd) + lon);
  const ha = rad(mod360(lst - raDeg));
  const latR = rad(lat);
  const decR = rad(decDeg);
  const sinAlt = Math.sin(decR) * Math.sin(latR) + Math.cos(decR) * Math.cos(latR) * Math.cos(ha);
  const alt = deg(Math.asin(Math.max(-1, Math.min(1, sinAlt))));
  const cosAz = (Math.sin(decR) - sinAlt * Math.sin(latR)) / (Math.cos(rad(alt)) * Math.cos(latR));
  let az = deg(Math.acos(Math.max(-1, Math.min(1, cosAz))));
  if (Math.sin(ha) > 0) az = 360 - az;
  return { alt, az };
}

function project(alt: number, az: number, R: number, cx: number, cy: number) {
  if (alt < -1) return null;
  const r = (90 - Math.max(0, alt)) / 90 * R;
  const azR = rad(az);
  return { x: cx - r * Math.sin(azR), y: cy - r * Math.cos(azR) };
}

// ─── Kepler solver (Newton-Raphson, returns E in radians)
function solveKepler(Mdeg: number, e: number) {
  let E = rad(Mdeg);
  const Mrad = rad(Mdeg);
  for (let i = 0; i < 15; i++) {
    const dE = (E - e * Math.sin(E) - Mrad) / (1 - e * Math.cos(E));
    E -= dE;
    if (Math.abs(dE) < 1e-10) break;
  }
  return E;
}

// ─── Heliocentric ecliptic XYZ for a planet
function helioXYZ(name: string, T: number) {
  const o = OE[name];
  const L  = mod360(o[0] + o[1] * T);
  const a  = o[2];
  const e  = o[3] + o[4] * T;
  const iR = rad(o[5] + o[6] * T);
  const OR = rad(mod360(o[7] + o[8] * T));
  const wt = mod360(o[9] + o[10] * T);  // longitude of perihelion
  const M  = mod360(L - wt);
  const wR = rad(mod360(wt - (o[7] + o[8] * T)));  // argument of perihelion
  const E  = solveKepler(M, e);
  const nu = 2 * Math.atan2(Math.sqrt(1+e)*Math.sin(E/2), Math.sqrt(1-e)*Math.cos(E/2));
  const r  = a * (1 - e * Math.cos(E));
  const x  = r*(Math.cos(OR)*Math.cos(nu+wR) - Math.sin(OR)*Math.sin(nu+wR)*Math.cos(iR));
  const y  = r*(Math.sin(OR)*Math.cos(nu+wR) + Math.cos(OR)*Math.sin(nu+wR)*Math.cos(iR));
  const z  = r*Math.sin(nu+wR)*Math.sin(iR);
  return { x, y, z };
}

// ─── Geocentric equatorial RA/Dec for a planet (degrees)
function planetRaDec(name: string, jd: number) {
  const T = (jd - 2451545.0) / 36525;
  const p = helioXYZ(name, T);
  const e = helioXYZ('earth', T);
  const dx = p.x - e.x, dy = p.y - e.y, dz = p.z - e.z;
  const eps = rad(23.439291 - 0.013004 * T);
  const X = dx;
  const Y = dy * Math.cos(eps) - dz * Math.sin(eps);
  const Z = dy * Math.sin(eps) + dz * Math.cos(eps);
  return {
    ra:  mod360(deg(Math.atan2(Y, X))),
    dec: deg(Math.asin(Z / Math.sqrt(X*X+Y*Y+Z*Z))),
  };
}

// ─── Moon RA/Dec (simplified Meeus Ch.47)
function moonRaDec(jd: number) {
  const T = (jd - 2451545.0) / 36525;
  const L0 = mod360(218.3164591 + 481267.88134236 * T);
  const M  = rad(mod360(134.9634114 + 477198.8676313 * T));
  const Ms = rad(mod360(357.5291092 +  35999.0502909 * T));
  const F  = rad(mod360( 93.2720993 + 483202.0175381 * T));
  const D  = rad(mod360(297.8503631 + 445267.1114034 * T));
  const dL = 6.289*Math.sin(M)     + 1.274*Math.sin(2*D-M)  + 0.658*Math.sin(2*D)
           - 0.214*Math.sin(2*M)   - 0.186*Math.sin(Ms)     - 0.114*Math.sin(2*F)
           + 0.059*Math.sin(2*D-2*M)- 0.057*Math.sin(2*D-M-Ms)
           + 0.053*Math.sin(2*D+M) + 0.046*Math.sin(2*D-Ms) + 0.041*Math.sin(M-Ms)
           - 0.035*Math.sin(D)     - 0.031*Math.sin(M+Ms);
  const dB = 5.128*Math.sin(F)     + 0.280*Math.sin(M+F)    - 0.277*Math.sin(M-F)
           - 0.173*Math.sin(2*D-F) - 0.055*Math.sin(2*D-M+F)- 0.046*Math.sin(2*D-M-F)
           + 0.033*Math.sin(2*D+F) + 0.017*Math.sin(2*M+F);
  const lon = rad(mod360(L0 + dL));
  const lat = rad(dB);
  const eps = rad(23.439291 - 0.013004 * T);
  return {
    ra:  mod360(deg(Math.atan2(Math.sin(lon)*Math.cos(eps)-Math.tan(lat)*Math.sin(eps), Math.cos(lon)))),
    dec: deg(Math.asin(Math.sin(lat)*Math.cos(eps) + Math.cos(lat)*Math.sin(eps)*Math.sin(lon))),
  };
}

// ─── Sun RA/Dec (simplified)
function sunRaDec(jd: number) {
  const n = jd - 2451545.0;
  const T = n / 36525;
  const L = mod360(280.460 + 0.9856474 * n);
  const g = rad(mod360(357.528 + 0.9856003 * n));
  const lam = rad(L + 1.915*Math.sin(g) + 0.020*Math.sin(2*g));
  const eps = rad(23.439 - 0.0000004 * n);
  return {
    ra:  mod360(deg(Math.atan2(Math.cos(eps)*Math.sin(lam), Math.cos(lam)))),
    dec: deg(Math.asin(Math.sin(eps)*Math.sin(lam))),
  };
}

// ─── Build star name → index lookup
const starIdx = new Map<string, number>();
STARS.forEach((s, i) => starIdx.set(s[4], i));

// ─── Draw
function draw(date: Date, lat: number, lon: number, bw = false, targetCanvas?: HTMLCanvasElement) {
  const canvas = targetCanvas ?? (document.getElementById('starmap-canvas') as HTMLCanvasElement);
  if (!canvas) return;
  const ctx = canvas.getContext('2d')!;
  const W = canvas.width, H = canvas.height;
  const R = Math.min(W, H) / 2 - 52;
  const cx = W / 2, cy = H / 2;
  const jd = julianDate(date);

  // Precompute alt/az for every star
  const altAz = STARS.map(s => toAltAz(s[0] * 15, s[1], lat, lon, jd));

  // Clear
  ctx.clearRect(0, 0, W, H);

  // Sky background
  const bg = ctx.createRadialGradient(cx, cy, 0, cx, cy, R);
  if (bw) {
    bg.addColorStop(0, '#ffffff');
    bg.addColorStop(1, '#f0f0f0');
  } else {
    bg.addColorStop(0, '#0d1030');
    bg.addColorStop(0.6, '#07091e');
    bg.addColorStop(1, '#020310');
  }
  ctx.beginPath(); ctx.arc(cx, cy, R, 0, Math.PI*2);
  ctx.fillStyle = bg; ctx.fill();

  // Clip to sky circle
  ctx.save();
  ctx.beginPath(); ctx.arc(cx, cy, R, 0, Math.PI*2); ctx.clip();

  // Altitude circles
  ctx.lineWidth = 1;
  [0, 30, 60].forEach(a => {
    ctx.strokeStyle = bw ? (a === 0 ? 'rgba(0,0,0,0.22)' : 'rgba(0,0,0,0.10)') : (a === 0 ? 'rgba(120,160,220,0.35)' : 'rgba(80,110,180,0.18)');
    ctx.beginPath(); ctx.arc(cx, cy, (90-a)/90*R, 0, Math.PI*2); ctx.stroke();
  });

  // Azimuth lines
  ctx.strokeStyle = bw ? 'rgba(0,0,0,0.06)' : 'rgba(80,110,180,0.10)';
  for (let az = 0; az < 360; az += 30) {
    const r = rad(az);
    ctx.beginPath();
    ctx.moveTo(cx, cy);
    ctx.lineTo(cx - R*Math.sin(r), cy - R*Math.cos(r));
    ctx.stroke();
  }

  // Constellation lines
  ctx.strokeStyle = bw ? 'rgba(0,0,0,0.18)' : 'rgba(100,140,220,0.28)';
  ctx.lineWidth = 0.8;
  for (const [a, b] of CONST_LINES) {
    const ia = starIdx.get(a), ib = starIdx.get(b);
    if (ia == null || ib == null) continue;
    const pa = project(altAz[ia].alt, altAz[ia].az, R, cx, cy);
    const pb = project(altAz[ib].alt, altAz[ib].az, R, cx, cy);
    if (!pa || !pb) continue;
    ctx.beginPath(); ctx.moveTo(pa.x, pa.y); ctx.lineTo(pb.x, pb.y); ctx.stroke();
  }

  // Stars
  for (let i = 0; i < STARS.length; i++) {
    const [, , mag, ci, name] = STARS[i];
    const { alt, az } = altAz[i];
    if (alt < 0) continue;
    const pt = project(alt, az, R, cx, cy)!;
    const r = Math.max(0.8, 4.2 - mag * 0.75);

    // Glow for bright stars
    if (mag < 1.5) {
      const g = ctx.createRadialGradient(pt.x, pt.y, 0, pt.x, pt.y, r*3.5);
      g.addColorStop(0, bw ? 'rgba(0,0,0,0.12)' : STAR_COLORS[ci] + '88');
      g.addColorStop(1, 'transparent');
      ctx.fillStyle = g;
      ctx.beginPath(); ctx.arc(pt.x, pt.y, r*3.5, 0, Math.PI*2); ctx.fill();
    }

    ctx.fillStyle = bw ? '#000000' : STAR_COLORS[ci];
    ctx.beginPath(); ctx.arc(pt.x, pt.y, r, 0, Math.PI*2); ctx.fill();

    // Label bright stars
    if (mag < 1.0 || name === 'Polaris') {
      ctx.font = '10px sans-serif';
      ctx.fillStyle = bw ? 'rgba(0,0,0,0.75)' : 'rgba(200,220,255,0.75)';
      ctx.textAlign = 'left';
      ctx.fillText(name, pt.x + r + 3, pt.y + 3);
    }
  }

  // Reset sidebar data
  visibleObjects = [];

  // Sun
  const sun = sunRaDec(jd);
  const sunAA = toAltAz(sun.ra, sun.dec, lat, lon, jd);
  const sunPt = project(sunAA.alt, sunAA.az, R, cx, cy);
  if (sunPt) {
    const g = ctx.createRadialGradient(sunPt.x, sunPt.y, 0, sunPt.x, sunPt.y, 20);
    g.addColorStop(0, bw ? 'rgba(0,0,0,0.2)' : '#ffffc0');
    g.addColorStop(0.3, bw ? 'rgba(0,0,0,0.08)' : '#ffcc40aa');
    g.addColorStop(1, 'transparent');
    ctx.fillStyle = g;
    ctx.beginPath(); ctx.arc(sunPt.x, sunPt.y, 20, 0, Math.PI*2); ctx.fill();
    ctx.fillStyle = bw ? '#333333' : '#ffee44';
    ctx.beginPath(); ctx.arc(sunPt.x, sunPt.y, 6, 0, Math.PI*2); ctx.fill();
    ctx.font = '10px sans-serif'; ctx.fillStyle = bw ? '#333333' : '#ffee44'; ctx.textAlign = 'left';
    ctx.fillText('Soleil', sunPt.x+8, sunPt.y+3);
  }

  // Moon
  const moon = moonRaDec(jd);
  const moonAA = toAltAz(moon.ra, moon.dec, lat, lon, jd);
  const moonPt = project(moonAA.alt, moonAA.az, R, cx, cy);
  if (moonPt) {
    const g = ctx.createRadialGradient(moonPt.x, moonPt.y, 0, moonPt.x, moonPt.y, 14);
    g.addColorStop(0, bw ? 'rgba(0,0,0,0.15)' : '#ffffff');
    g.addColorStop(0.4, bw ? 'rgba(0,0,0,0.06)' : '#ccccee88');
    g.addColorStop(1, 'transparent');
    ctx.fillStyle = g;
    ctx.beginPath(); ctx.arc(moonPt.x, moonPt.y, 14, 0, Math.PI*2); ctx.fill();
    ctx.fillStyle = bw ? '#444444' : '#dde4ff';
    ctx.beginPath(); ctx.arc(moonPt.x, moonPt.y, 5, 0, Math.PI*2); ctx.fill();
    ctx.font = '10px sans-serif'; ctx.fillStyle = bw ? '#444444' : '#dde4ff'; ctx.textAlign = 'left';
    ctx.fillText('Lune', moonPt.x+8, moonPt.y+3);
    visibleObjects.push({ x: moonPt.x, y: moonPt.y, name: 'Lune', desc: 'Cible n°1 pour débuter ! Observez les cratères, les mers (grandes plaines sombres) et les chaînes de montagnes. Idéale aux phases croissante et décroissante.', type: 'moon', alt: moonAA.alt });
  }

  // Planets
  for (const [pname, [color, label]] of Object.entries(PLANET_DISPLAY)) {
    try {
      const pos = planetRaDec(pname, jd);
      const aa = toAltAz(pos.ra, pos.dec, lat, lon, jd);
      if (aa.alt < 0) continue;
      const pt = project(aa.alt, aa.az, R, cx, cy)!;
      const g = ctx.createRadialGradient(pt.x, pt.y, 0, pt.x, pt.y, 10);
      g.addColorStop(0, bw ? 'rgba(0,0,0,0.15)' : color);
      g.addColorStop(1, 'transparent');
      ctx.fillStyle = g;
      ctx.beginPath(); ctx.arc(pt.x, pt.y, 10, 0, Math.PI*2); ctx.fill();
      ctx.fillStyle = bw ? '#333333' : color;
      ctx.beginPath(); ctx.arc(pt.x, pt.y, 4, 0, Math.PI*2); ctx.fill();
      ctx.font = '10px sans-serif'; ctx.fillStyle = bw ? '#333333' : color; ctx.textAlign = 'left';
      ctx.fillText(label, pt.x+7, pt.y+3);
      visibleObjects.push({ x: pt.x, y: pt.y, name: label, desc: PLANET_DESC[pname] || '', type: 'planet', alt: aa.alt });
    } catch(_) {}
  }

  // Deep Sky Objects
  dsoPositions = [];
  const dsoColor: Record<string,string> = bw
    ? { neb:'#333333', oc:'#333333', gc:'#444444', gal:'#555555', db:'#333333' }
    : { neb:'#44ffcc', oc:'#ffdd44', gc:'#88ccff', gal:'#ff88cc', db:'rgba(220,240,255,0.85)' };

  function drawDSOSymbol(cx2: number, cy2: number, type: string) {
    const s = 8;
    ctx.lineWidth = 1.2;
    ctx.setLineDash([]);
    ctx.strokeStyle = dsoColor[type] || '#ffffff';
    switch (type) {
      case 'neb':
        ctx.setLineDash([2,2]);
        ctx.strokeRect(cx2-s, cy2-s, s*2, s*2);
        ctx.setLineDash([]);
        break;
      case 'oc':
        ctx.setLineDash([2,2]);
        ctx.beginPath(); ctx.arc(cx2, cy2, s, 0, Math.PI*2); ctx.stroke();
        ctx.setLineDash([]);
        break;
      case 'gc':
        ctx.beginPath(); ctx.arc(cx2, cy2, s, 0, Math.PI*2); ctx.stroke();
        ctx.beginPath(); ctx.moveTo(cx2-s, cy2); ctx.lineTo(cx2+s, cy2); ctx.stroke();
        ctx.beginPath(); ctx.moveTo(cx2, cy2-s); ctx.lineTo(cx2, cy2+s); ctx.stroke();
        break;
      case 'gal':
        ctx.beginPath();
        ctx.ellipse(cx2, cy2, s*1.6, s*0.55, 0, 0, Math.PI*2);
        ctx.stroke();
        break;
      case 'db':
        ctx.beginPath(); ctx.arc(cx2-3, cy2, 4, 0, Math.PI*2); ctx.stroke();
        ctx.beginPath(); ctx.arc(cx2+3, cy2, 4, 0, Math.PI*2); ctx.stroke();
        break;
    }
  }

  for (const [ra, dec, name, type, desc] of DSO) {
    const aa = toAltAz(ra * 15, dec, lat, lon, jd);
    if (aa.alt < 0) continue;
    const pt = project(aa.alt, aa.az, R, cx, cy)!;
    drawDSOSymbol(pt.x, pt.y, type);
    const parts = name.split(' — ');
    const canvasLabel = parts.length > 1 ? parts[1] : parts[0];
    ctx.font = '9px sans-serif';
    ctx.fillStyle = dsoColor[type] || '#ffffff';
    ctx.textAlign = 'left';
    ctx.fillText(canvasLabel, pt.x + 11, pt.y + 3);
    dsoPositions.push({ x: pt.x, y: pt.y, name, desc });
    visibleObjects.push({ x: pt.x, y: pt.y, name, desc, type, alt: aa.alt });
  }

  // Highlight ring for selected object
  if (highlightIdx >= 0 && highlightIdx < visibleObjects.length) {
    const h = visibleObjects[highlightIdx];
    ctx.strokeStyle = bw ? 'rgba(120,0,0,0.85)' : 'rgba(255,60,60,0.95)';
    ctx.lineWidth = 2;
    ctx.setLineDash([5,3]);
    ctx.beginPath(); ctx.arc(h.x, h.y, 20, 0, Math.PI*2); ctx.stroke();
    ctx.setLineDash([]);
  }

  ctx.restore();

  // Horizon ring
  ctx.strokeStyle = bw ? 'rgba(0,0,0,0.45)' : 'rgba(120,160,220,0.5)';
  ctx.lineWidth = 1.5;
  ctx.beginPath(); ctx.arc(cx, cy, R, 0, Math.PI*2); ctx.stroke();

  // Cardinal directions
  const cards = [['N',0],['E',90],['S',180],['O',270]] as [string,number][];
  for (const [lbl, az] of cards) {
    const r2 = rad(az);
    const x = cx - (R+28)*Math.sin(r2);
    const y = cy - (R+28)*Math.cos(r2);
    ctx.fillStyle = bw ? 'rgba(245,245,245,0.97)' : 'rgba(10,15,45,0.8)';
    ctx.beginPath(); ctx.arc(x, y, 15, 0, Math.PI*2); ctx.fill();
    ctx.strokeStyle = bw ? 'rgba(0,0,0,0.28)' : 'rgba(100,130,200,0.4)';
    ctx.lineWidth = 1;
    ctx.beginPath(); ctx.arc(x, y, 15, 0, Math.PI*2); ctx.stroke();
    ctx.font = 'bold 17px sans-serif';
    ctx.fillStyle = bw ? '#111111' : '#aabbee';
    ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
    ctx.fillText(lbl, x, y);
  }

  // Date/time label
  const dateLabel = date.toLocaleDateString('fr-FR', {weekday:'long',day:'numeric',month:'long',year:'numeric'})
    + ' — ' + date.toLocaleTimeString('fr-FR',{hour:'2-digit',minute:'2-digit'});
  ctx.font = '11px sans-serif'; ctx.fillStyle = bw ? 'rgba(0,0,0,0.5)' : 'rgba(160,180,220,0.7)';
  ctx.textAlign = 'center'; ctx.textBaseline = 'bottom';
  ctx.fillText(dateLabel, cx, H - 6);
}

// ─── Sidebar
const TYPE_LABELS: Record<string,string> = {
  moon:'Lune', planet:'Planètes', neb:'Nébuleuses',
  oc:'Amas ouverts', gc:'Amas globulaires', gal:'Galaxies', db:'Étoiles doubles',
};
const TYPE_COLOR: Record<string,string> = {
  moon:'#dde4ff', planet:'#ffd8a0', neb:'#44ffcc',
  oc:'#ffdd44', gc:'#88ccff', gal:'#ff88cc', db:'rgba(220,240,255,0.85)',
};
const TYPE_ORDER = ['moon','planet','neb','oc','gc','gal','db'];

function populateSidebar() {
  const list = document.getElementById('sm-list');
  const detail = document.getElementById('sm-detail');
  if (!list || !detail) return;

  if (visibleObjects.length === 0) {
    list.innerHTML = '<p class="sidebar-empty">Génère la carte pour voir les objets visibles.</p>';
    detail.innerHTML = '';
    return;
  }

  const groups: Record<string, VisibleObj[]> = {};
  for (const obj of visibleObjects) {
    if (!groups[obj.type]) groups[obj.type] = [];
    groups[obj.type].push(obj);
  }

  let html = '';
  for (const t of TYPE_ORDER) {
    const objs = groups[t];
    if (!objs?.length) continue;
    html += `<div class="sidebar-group"><div class="sidebar-group-label" style="color:${TYPE_COLOR[t]}">${TYPE_LABELS[t] || t}</div>`;
    for (const obj of objs) {
      const idx = visibleObjects.indexOf(obj);
      const nameParts = obj.name.split(' — ');
      const shortName = nameParts.length > 1 ? nameParts[1] : nameParts[0];
      const isActive = idx === highlightIdx;
      html += `<button class="sidebar-item${isActive ? ' active' : ''}" data-idx="${idx}" style="--ic:${TYPE_COLOR[obj.type]}">
        <span class="sidebar-name">${shortName}</span>
      </button>`;
    }
    html += '</div>';
  }
  list.innerHTML = html;

  // Update detail panel if something is selected
  if (highlightIdx >= 0 && visibleObjects[highlightIdx]) {
    const obj = visibleObjects[highlightIdx];
    detail.innerHTML = `<strong>${obj.name}</strong><p>${obj.desc}</p>`;
  }

  list.querySelectorAll<HTMLButtonElement>('.sidebar-item').forEach(btn => {
    btn.addEventListener('click', () => {
      const idx = parseInt(btn.dataset.idx ?? '-1');
      highlightIdx = highlightIdx === idx ? -1 : idx;
      if (highlightIdx < 0) detail.innerHTML = '';
      const { date, lat, lon } = getParams();
      draw(date, lat, lon);
      populateSidebar();
    });
  });
}

// ─── UI
function defaultDatetime() {
  const d = new Date();
  d.setHours(22, 0, 0, 0);
  // If before noon, show yesterday night
  if (new Date().getHours() < 12) d.setDate(d.getDate() - 1);
  // format yyyy-MM-ddTHH:mm
  const pad = (n: number) => String(n).padStart(2,'0');
  return `${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())}T${pad(d.getHours())}:${pad(d.getMinutes())}`;
}

function getParams(): { date: Date; lat: number; lon: number } {
  const dtInput = document.getElementById('sm-datetime') as HTMLInputElement;
  const citySelect = document.getElementById('sm-city') as HTMLSelectElement;
  const [lat, lon] = citySelect.value.split(',').map(Number);
  const date = dtInput.value ? new Date(dtInput.value) : new Date();
  return { date, lat, lon };
}

function updateInfo(date: Date, lat: number, lon: number) {
  const jd = julianDate(date);
  const sun = sunRaDec(jd);
  const sunAlt = toAltAz(sun.ra, sun.dec, lat, lon, jd).alt;
  const info = document.getElementById('sm-info');
  if (!info) return;
  if (sunAlt > 0) {
    info.textContent = `Le Soleil est encore au-dessus de l'horizon (${sunAlt.toFixed(0)}°). Les étoiles ne sont pas encore visibles.`;
    info.style.color = '#ffcc44';
  } else if (sunAlt > -6) {
    info.textContent = `Crépuscule civil — le ciel commence à s'assombrir.`;
    info.style.color = '#aabbff';
  } else if (sunAlt > -12) {
    info.textContent = `Crépuscule nautique — bonnes conditions pour les étoiles brillantes.`;
    info.style.color = '#aabbff';
  } else {
    info.textContent = `Nuit astronomique — toutes les étoiles sont visibles.`;
    info.style.color = '#88aaff';
  }
}

document.addEventListener('DOMContentLoaded', () => {
  const dtInput = document.getElementById('sm-datetime') as HTMLInputElement;
  dtInput.value = defaultDatetime();

  const btn = document.getElementById('sm-generate')!;
  btn.addEventListener('click', () => {
    const { date, lat, lon } = getParams();
    highlightIdx = -1;
    draw(date, lat, lon);
    updateInfo(date, lat, lon);
    populateSidebar();
  });

  // Geolocation
  document.getElementById('sm-geolocate')!.addEventListener('click', () => {
    if (!navigator.geolocation) return;
    const btn = document.getElementById('sm-geolocate') as HTMLButtonElement;
    btn.textContent = '…';
    navigator.geolocation.getCurrentPosition(pos => {
      const lat = pos.coords.latitude, lon = pos.coords.longitude;
      const sel = document.getElementById('sm-city') as HTMLSelectElement;
      // Add a custom option
      const opt = document.createElement('option');
      opt.value = `${lat.toFixed(4)},${lon.toFixed(4)}`;
      opt.text = `Ma position (${lat.toFixed(2)}°, ${lon.toFixed(2)}°)`;
      opt.selected = true;
      sel.insertBefore(opt, sel.firstChild);
      btn.textContent = '✓ Localisé';
      const { date } = getParams();
      highlightIdx = -1;
      draw(date, lat, lon);
      updateInfo(date, lat, lon);
      populateSidebar();
    }, () => { btn.textContent = 'Ma position'; });
  });

  // Export A4 N&B pour impression
  document.getElementById('sm-print-a4')!.addEventListener('click', async () => {
    const btn = document.getElementById('sm-print-a4') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Génération…';

    const { date, lat, lon } = getParams();
    const citySelect = document.getElementById('sm-city') as HTMLSelectElement;
    const cityName = citySelect.options[citySelect.selectedIndex]?.text ?? '';

    // 1. Dessiner la carte en N&B sur le canvas existant (haute résolution via upscale)
    const mapCanvas = document.getElementById('starmap-canvas') as HTMLCanvasElement;
    const origW = mapCanvas.width, origH = mapCanvas.height;
    mapCanvas.width = 1100; mapCanvas.height = 1100;
    draw(date, lat, lon, true);

    // 2. Canvas A4 à 150 DPI (210mm × 297mm)
    const A4W = 1240, A4H = 1754;
    const off = document.createElement('canvas');
    off.width = A4W; off.height = A4H;
    const ctx = off.getContext('2d')!;

    // Fond blanc
    ctx.fillStyle = '#ffffff';
    ctx.fillRect(0, 0, A4W, A4H);

    const margin = 70;
    let y = margin;

    // --- Logo ---
    const logo = new Image();
    logo.src = '/assets/logolumi.png';
    await new Promise<void>(res => { logo.onload = () => res(); logo.onerror = () => res(); });
    if (logo.naturalWidth > 0) {
      const logoH = 56;
      const logoW = Math.round(logo.naturalWidth * (logoH / logo.naturalHeight));
      ctx.drawImage(logo, margin, y, logoW, logoH);
    }

    // Titre aligné à droite du logo
    ctx.font = 'bold 30px Georgia, serif';
    ctx.fillStyle = '#111111';
    ctx.textAlign = 'right';
    ctx.textBaseline = 'top';
    ctx.fillText('Carte du ciel', A4W - margin, y + 4);
    ctx.font = '16px sans-serif';
    ctx.fillStyle = '#555555';
    const dateStr = date.toLocaleDateString('fr-FR', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' })
      + ' — ' + date.toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' });
    ctx.fillText(dateStr, A4W - margin, y + 40);
    ctx.fillText(cityName, A4W - margin, y + 62);

    y += 80;

    // Ligne de séparation
    ctx.strokeStyle = 'rgba(0,0,0,0.15)';
    ctx.lineWidth = 1;
    ctx.beginPath(); ctx.moveTo(margin, y); ctx.lineTo(A4W - margin, y); ctx.stroke();
    y += 24;

    // --- Carte du ciel ---
    const mapSize = 1100;
    const mapX = Math.round((A4W - mapSize) / 2);
    ctx.drawImage(mapCanvas, mapX, y);
    y += mapSize + 20;

    // Ligne de séparation
    ctx.strokeStyle = 'rgba(0,0,0,0.15)';
    ctx.beginPath(); ctx.moveTo(margin, y); ctx.lineTo(A4W - margin, y); ctx.stroke();
    y += 18;

    // --- Légende orientations ---
    ctx.font = '13px sans-serif';
    ctx.fillStyle = '#444444';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'top';
    ctx.fillText('N = Nord  ·  E = Est  ·  S = Sud  ·  O = Ouest  —  vue depuis le sol, Nord en haut', A4W / 2, y);
    y += 22;

    // --- Légende objets DSO (dessinés au trait) ---
    const dsoItems: [string, (cx: number, cy: number) => void][] = [
      ['Nébuleuse', (cx, cy) => {
        ctx.setLineDash([3, 2]); ctx.strokeRect(cx - 7, cy - 7, 14, 14); ctx.setLineDash([]);
      }],
      ['Amas ouvert', (cx, cy) => {
        ctx.setLineDash([3, 2]); ctx.beginPath(); ctx.arc(cx, cy, 7, 0, Math.PI * 2); ctx.stroke(); ctx.setLineDash([]);
      }],
      ['Amas globulaire', (cx, cy) => {
        ctx.beginPath(); ctx.arc(cx, cy, 7, 0, Math.PI * 2); ctx.stroke();
        ctx.beginPath(); ctx.moveTo(cx - 7, cy); ctx.lineTo(cx + 7, cy); ctx.stroke();
        ctx.beginPath(); ctx.moveTo(cx, cy - 7); ctx.lineTo(cx, cy + 7); ctx.stroke();
      }],
      ['Galaxie', (cx, cy) => {
        ctx.beginPath(); ctx.ellipse(cx, cy, 11, 4, 0, 0, Math.PI * 2); ctx.stroke();
      }],
      ['Étoile double', (cx, cy) => {
        ctx.beginPath(); ctx.arc(cx - 4, cy, 4, 0, Math.PI * 2); ctx.stroke();
        ctx.beginPath(); ctx.arc(cx + 4, cy, 4, 0, Math.PI * 2); ctx.stroke();
      }],
    ];
    ctx.strokeStyle = '#333333';
    ctx.lineWidth = 1.2;
    ctx.font = '12px sans-serif';
    ctx.fillStyle = '#444444';
    ctx.textAlign = 'left';
    const colW = (A4W - 2 * margin) / dsoItems.length;
    dsoItems.forEach(([label, drawFn], i) => {
      const ix = margin + i * colW + colW / 2 - 40;
      drawFn(ix + 8, y + 8);
      ctx.fillText(label, ix + 20, y + 3);
    });
    y += 30;

    // Ligne finale
    ctx.strokeStyle = 'rgba(0,0,0,0.10)';
    ctx.lineWidth = 1;
    ctx.beginPath(); ctx.moveTo(margin, y); ctx.lineTo(A4W - margin, y); ctx.stroke();
    y += 14;

    // --- Footer ---
    ctx.font = '12px sans-serif';
    ctx.fillStyle = '#999999';
    ctx.textAlign = 'center';
    ctx.fillText('la3emedim.fr — Lunette astronomique Lumi', A4W / 2, y);

    // 3. Télécharger
    const link = document.createElement('a');
    link.download = 'carte-du-ciel-lumi.png';
    link.href = off.toDataURL('image/png');
    link.click();

    // 4. Restaurer le canvas normal
    mapCanvas.width = origW; mapCanvas.height = origH;
    draw(date, lat, lon, false);

    btn.disabled = false;
    btn.innerHTML = `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 01-2-2v-5a2 2 0 012-2h16a2 2 0 012 2v5a2 2 0 01-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg> Imprimer A4 N&B`;
  });

  // ─── Voie Lactée : waypoints [RA_deg, Dec_deg] le long du plan galactique
  const MILKY_WAY: [number,number][] = [
    [266.4,-28.9],[280,-15],[295,0],[310,18],[325,35],[340,50],[355,60],
    [15,65],[35,60],[55,50],[75,35],[90,20],[100,7],[115,-6],[130,-20],
    [145,-36],[160,-48],[175,-55],[190,-57],[210,-55],[225,-50],
    [240,-43],[253,-35],[266.4,-28.9],
  ];

  // ─── Projection gnomonique (perspective réelle, comme Stellarium)
  function projectGnomonic(
    altDeg: number, azDeg: number,
    azCDeg: number, altCDeg: number,
    fovDeg: number, W: number, H: number
  ): {x: number, y: number} | null {
    const r = Math.PI / 180;
    const altR = altDeg * r, azR = azDeg * r;
    const px = Math.cos(altR) * Math.sin(azR);
    const py = Math.sin(altR);
    const pz = Math.cos(altR) * Math.cos(azR);
    const altCR = altCDeg * r, azCR = azCDeg * r;
    const fx = Math.cos(altCR) * Math.sin(azCR);
    const fy = Math.sin(altCR);
    const fz = Math.cos(altCR) * Math.cos(azCR);
    const depth = px*fx + py*fy + pz*fz;
    if (depth <= 0.001) return null;
    // Up = world Y projeté perpendiculaire au forward
    let ux = -fy*fx, uy = 1 - fy*fy, uz = -fy*fz;
    let uLen = Math.sqrt(ux*ux + uy*uy + uz*uz);
    if (uLen < 0.001) { // gimbal (zénith/nadir) : utilise Nord
      ux = -fz*fx; uy = -fz*fy; uz = 1 - fz*fz;
      uLen = Math.sqrt(ux*ux + uy*uy + uz*uz);
    }
    ux /= uLen; uy /= uLen; uz /= uLen;
    // Right = fwd × up
    const rx = fy*uz - fz*uy, ry = fz*ux - fx*uz, rz = fx*uy - fy*ux;
    const scale = (W / 2) / Math.tan(fovDeg * r / 2);
    return {
      x: (px*rx + py*ry + pz*rz) / depth * scale + W / 2,
      y: -(px*ux + py*uy + pz*uz) / depth * scale + H / 2,
    };
  }

  // ─── État de la caméra plein écran
  let fsAzC = 180, fsAltC = 30, fsFov = 90;
  type FsCelPos = { x: number; y: number; name: string; desc: string; r: number };
  let fsCelestialPositions: FsCelPos[] = [];

  // ─── Rendu plein écran — projection gnomonique
  function drawFullscreen(fsCanvas: HTMLCanvasElement, date: Date, lat: number, lon: number) {
    const ctx = fsCanvas.getContext('2d')!;
    const W = fsCanvas.width, H = fsCanvas.height;
    const jd = julianDate(date);
    const altAz = STARS.map(s => toAltAz(s[0] * 15, s[1], lat, lon, jd));
    fsCelestialPositions = [];

    function proj(alt: number, az: number) {
      return projectGnomonic(alt, az, fsAzC, fsAltC, fsFov, W, H);
    }

    // Fond ciel
    ctx.fillStyle = '#010208';
    ctx.fillRect(0, 0, W, H);

    // ── Sol : polygone sous l'horizon projeté
    {
      const hpts: {x:number,y:number}[] = [];
      for (let az = 0; az <= 358; az += 2) {
        const p = proj(0, az);
        if (p && p.x > -W && p.x < 2*W && p.y > -H && p.y < 2*H) hpts.push(p);
      }
      if (hpts.length >= 2) {
        hpts.sort((a, b) => a.x - b.x);
        ctx.save();
        ctx.beginPath();
        ctx.moveTo(hpts[0].x, H + 10);
        ctx.lineTo(hpts[0].x, hpts[0].y);
        for (let i = 1; i < hpts.length; i++) ctx.lineTo(hpts[i].x, hpts[i].y);
        ctx.lineTo(hpts[hpts.length - 1].x, H + 10);
        ctx.closePath();
        const gGrad = ctx.createLinearGradient(0, H * 0.55, 0, H);
        gGrad.addColorStop(0, '#0b1607'); gGrad.addColorStop(1, '#020803');
        ctx.fillStyle = gGrad; ctx.fill();
        ctx.restore();
      } else if (fsAltC < 0) {
        ctx.fillStyle = '#040c02'; ctx.fillRect(0, 0, W, H);
      }
    }

    // Lueur atmosphérique autour de l'horizon
    {
      const p0 = proj(0, fsAzC);
      if (p0) {
        const atmo = ctx.createRadialGradient(W/2, p0.y, 0, W/2, p0.y, H * 0.4);
        atmo.addColorStop(0, 'rgba(30,60,140,0.10)');
        atmo.addColorStop(0.5, 'rgba(15,45,15,0.08)');
        atmo.addColorStop(1, 'transparent');
        ctx.fillStyle = atmo; ctx.fillRect(0, 0, W, H);
      }
    }

    // ── Voie Lactée
    ctx.save();
    ctx.lineWidth = 50; ctx.lineCap = 'round'; ctx.lineJoin = 'round';
    const mwPts = MILKY_WAY.map(([ra, dec]) => {
      const aa = toAltAz(ra, dec, lat, lon, jd);
      return { pt: proj(aa.alt, aa.az), alt: aa.alt };
    });
    for (let i = 0; i < mwPts.length - 1; i++) {
      const a = mwPts[i], b = mwPts[i + 1];
      if (!a.pt || !b.pt) continue;
      if (Math.hypot(a.pt.x - b.pt.x, a.pt.y - b.pt.y) > W * 0.8) continue;
      const grad = ctx.createLinearGradient(a.pt.x, a.pt.y, b.pt.x, b.pt.y);
      grad.addColorStop(0, 'rgba(170,195,255,0.07)');
      grad.addColorStop(1, 'rgba(200,215,255,0.05)');
      ctx.strokeStyle = grad;
      ctx.beginPath(); ctx.moveTo(a.pt.x, a.pt.y); ctx.lineTo(b.pt.x, b.pt.y); ctx.stroke();
    }
    ctx.restore();

    // ── Grille altitude (cercles projetés en courbes)
    ctx.lineWidth = 1;
    for (const alt of [10, 20, 30, 45, 60, 75]) {
      const pts: {x:number,y:number}[] = [];
      for (let az = 0; az < 360; az += 3) { const p = proj(alt, az); if (p) pts.push(p); }
      if (pts.length < 3) continue;
      ctx.strokeStyle = 'rgba(70,95,200,0.09)';
      ctx.beginPath(); ctx.moveTo(pts[0].x, pts[0].y);
      pts.slice(1).forEach(p => ctx.lineTo(p.x, p.y));
      ctx.closePath(); ctx.stroke();
      ctx.fillStyle = 'rgba(100,120,200,0.32)'; ctx.font = '10px sans-serif';
      ctx.textAlign = 'left'; ctx.textBaseline = 'bottom';
      ctx.fillText(`${alt}°`, pts[0].x + 3, pts[0].y - 2);
    }

    // ── Grille azimut (méridiens)
    ctx.strokeStyle = 'rgba(70,95,180,0.06)'; ctx.lineWidth = 1;
    for (let az = 0; az < 360; az += 30) {
      const pts: {x:number,y:number}[] = [];
      for (let alt = 0; alt <= 88; alt += 4) { const p = proj(alt, az); if (p) pts.push(p); }
      if (pts.length < 2) continue;
      ctx.beginPath(); ctx.moveTo(pts[0].x, pts[0].y);
      pts.slice(1).forEach(p => ctx.lineTo(p.x, p.y)); ctx.stroke();
    }

    // ── Constellations
    ctx.lineWidth = 0.9;
    for (const [a, b] of CONST_LINES) {
      const ia = starIdx.get(a), ib = starIdx.get(b);
      if (ia == null || ib == null) continue;
      const pa = proj(altAz[ia].alt, altAz[ia].az);
      const pb = proj(altAz[ib].alt, altAz[ib].az);
      if (!pa || !pb) continue;
      if (Math.hypot(pa.x - pb.x, pa.y - pb.y) > W * 0.7) continue;
      ctx.strokeStyle = 'rgba(75,110,210,0.30)';
      ctx.beginPath(); ctx.moveTo(pa.x, pa.y); ctx.lineTo(pb.x, pb.y); ctx.stroke();
    }

    // ── Étoiles
    for (let i = 0; i < STARS.length; i++) {
      const [,, mag, ci, name] = STARS[i];
      const { alt, az } = altAz[i];
      if (alt < 0) continue;
      const p = proj(alt, az);
      if (!p || p.x < -150 || p.x > W+150 || p.y < -150 || p.y > H+150) continue;
      const r = Math.max(0.7, 4.6 - mag * 0.78);
      if (mag < 2.8) {
        const g = ctx.createRadialGradient(p.x,p.y,0,p.x,p.y,r*4.5);
        g.addColorStop(0, STAR_COLORS[ci]+'aa'); g.addColorStop(1,'transparent');
        ctx.fillStyle=g; ctx.beginPath(); ctx.arc(p.x,p.y,r*4.5,0,Math.PI*2); ctx.fill();
      }
      if (mag < 1.2) {
        ctx.strokeStyle=STAR_COLORS[ci]+'55'; ctx.lineWidth=0.9;
        const sp=r*7;
        ctx.beginPath(); ctx.moveTo(p.x-sp,p.y); ctx.lineTo(p.x+sp,p.y); ctx.stroke();
        ctx.beginPath(); ctx.moveTo(p.x,p.y-sp); ctx.lineTo(p.x,p.y+sp); ctx.stroke();
      }
      ctx.fillStyle=STAR_COLORS[ci];
      ctx.beginPath(); ctx.arc(p.x,p.y,r,0,Math.PI*2); ctx.fill();
      if (mag < 1.6 || name === 'Polaris') {
        ctx.font='11px sans-serif'; ctx.fillStyle='rgba(200,215,255,0.72)';
        ctx.textAlign='left'; ctx.textBaseline='middle';
        ctx.fillText(name, p.x+r+4, p.y);
      }
      if (name) fsCelestialPositions.push({ x: p.x, y: p.y, name, desc: `Magnitude ${mag.toFixed(1)} · Az ${Math.round(az)}° Alt ${Math.round(alt)}°`, r: Math.max(10, r * 3) });
    }

    // ── Soleil
    { const sun = sunRaDec(jd); const sunAA = toAltAz(sun.ra, sun.dec, lat, lon, jd);
      const p = proj(sunAA.alt, sunAA.az);
      if (p && sunAA.alt > 0) {
        const g = ctx.createRadialGradient(p.x,p.y,0,p.x,p.y,28);
        g.addColorStop(0,'#ffffc0'); g.addColorStop(0.35,'#ffcc40aa'); g.addColorStop(1,'transparent');
        ctx.fillStyle=g; ctx.beginPath(); ctx.arc(p.x,p.y,28,0,Math.PI*2); ctx.fill();
        ctx.fillStyle='#ffee44'; ctx.beginPath(); ctx.arc(p.x,p.y,7,0,Math.PI*2); ctx.fill();
        ctx.font='11px sans-serif'; ctx.fillStyle='#ffee44'; ctx.textAlign='left'; ctx.textBaseline='middle';
        ctx.fillText('Soleil', p.x+12, p.y);
        fsCelestialPositions.push({ x: p.x, y: p.y, name: 'Soleil', desc: 'Notre étoile. Ne jamais observer à l\'œil nu ou avec un instrument sans filtre solaire adapté.', r: 28 });
      }
    }

    // ── Lune
    { const moon = moonRaDec(jd); const moonAA = toAltAz(moon.ra, moon.dec, lat, lon, jd);
      const p = proj(moonAA.alt, moonAA.az);
      if (p && moonAA.alt > 0) {
        const g = ctx.createRadialGradient(p.x,p.y,0,p.x,p.y,18);
        g.addColorStop(0,'#ffffff'); g.addColorStop(0.4,'#ccccee88'); g.addColorStop(1,'transparent');
        ctx.fillStyle=g; ctx.beginPath(); ctx.arc(p.x,p.y,18,0,Math.PI*2); ctx.fill();
        ctx.fillStyle='#dde4ff'; ctx.beginPath(); ctx.arc(p.x,p.y,6,0,Math.PI*2); ctx.fill();
        ctx.font='11px sans-serif'; ctx.fillStyle='#dde4ff'; ctx.textAlign='left'; ctx.textBaseline='middle';
        ctx.fillText('Lune', p.x+10, p.y);
        fsCelestialPositions.push({ x: p.x, y: p.y, name: 'Lune', desc: 'Cible n°1 pour débuter ! Observez les cratères, les mers (grandes plaines sombres) et les chaînes de montagnes. Idéale aux phases croissante et décroissante.', r: 18 });
      }
    }

    // ── Planètes
    for (const [pname,[color,label]] of Object.entries(PLANET_DISPLAY)) {
      try {
        const pos = planetRaDec(pname, jd);
        const aa = toAltAz(pos.ra, pos.dec, lat, lon, jd);
        if (aa.alt < 0) continue;
        const p = proj(aa.alt, aa.az); if (!p) continue;
        const g = ctx.createRadialGradient(p.x,p.y,0,p.x,p.y,12);
        g.addColorStop(0,color); g.addColorStop(1,'transparent');
        ctx.fillStyle=g; ctx.beginPath(); ctx.arc(p.x,p.y,12,0,Math.PI*2); ctx.fill();
        ctx.fillStyle=color; ctx.beginPath(); ctx.arc(p.x,p.y,4,0,Math.PI*2); ctx.fill();
        ctx.font='11px sans-serif'; ctx.fillStyle=color; ctx.textAlign='left'; ctx.textBaseline='middle';
        ctx.fillText(label, p.x+8, p.y);
        fsCelestialPositions.push({ x: p.x, y: p.y, name: label, desc: PLANET_DESC[pname] || '', r: 14 });
      } catch(_) {}
    }

    // ── Objets du ciel profond
    const fsoDsoColor: Record<string,string> = { neb:'#44ffcc', oc:'#ffdd44', gc:'#88ccff', gal:'#ff88cc', db:'rgba(220,240,255,0.85)' };
    for (const [ra, dec, name, type, desc] of DSO) {
      const aa = toAltAz(ra * 15, dec, lat, lon, jd);
      if (aa.alt < 0) continue;
      const p = proj(aa.alt, aa.az);
      if (!p || p.x < -20 || p.x > W+20 || p.y < -20 || p.y > H+20) continue;
      const col = fsoDsoColor[type] || '#ffffff';
      ctx.strokeStyle = col; ctx.fillStyle = col; ctx.lineWidth = 1.2; ctx.setLineDash([]);
      const s = 7;
      ctx.save(); ctx.globalAlpha = 0.8;
      ctx.translate(p.x, p.y);
      if (type === 'neb') { ctx.setLineDash([3,2]); ctx.strokeRect(-s,-s,s*2,s*2); ctx.setLineDash([]); }
      else if (type === 'oc') { ctx.beginPath(); ctx.arc(0,0,s,0,Math.PI*2); ctx.stroke(); ctx.globalAlpha=0.2; ctx.fill(); ctx.globalAlpha=0.8; }
      else if (type === 'gc') { ctx.beginPath(); ctx.arc(0,0,s,0,Math.PI*2); ctx.stroke(); ctx.beginPath(); ctx.moveTo(-s,0); ctx.lineTo(s,0); ctx.moveTo(0,-s); ctx.lineTo(0,s); ctx.stroke(); }
      else if (type === 'gal') { ctx.save(); ctx.scale(1.6,0.6); ctx.beginPath(); ctx.arc(0,0,s,0,Math.PI*2); ctx.restore(); ctx.stroke(); }
      else if (type === 'db') { ctx.beginPath(); ctx.arc(-3,0,3,0,Math.PI*2); ctx.fill(); ctx.beginPath(); ctx.arc(3,0,3,0,Math.PI*2); ctx.fill(); }
      ctx.restore();
      const parts = name.split(' — ');
      ctx.font='9px sans-serif'; ctx.fillStyle=col+'cc'; ctx.textAlign='left'; ctx.textBaseline='middle';
      ctx.fillText(parts.length > 1 ? parts[1] : parts[0], p.x+s+4, p.y);
      fsCelestialPositions.push({ x: p.x, y: p.y, name, desc, r: s + 6 });
    }

    // ── Points cardinaux projetés à l'horizon
    for (const [lbl, az] of [['N',0],['NE',45],['E',90],['SE',135],['S',180],['SO',225],['O',270],['NO',315]] as [string,number][]) {
      const p = proj(0, az);
      if (!p || p.x < -30 || p.x > W+30 || p.y < -30 || p.y > H+60) continue;
      ctx.strokeStyle='rgba(70,120,50,0.55)'; ctx.lineWidth=1;
      ctx.beginPath(); ctx.moveTo(p.x,p.y-14); ctx.lineTo(p.x,p.y+6); ctx.stroke();
      ctx.fillStyle = lbl.length===1 ? 'rgba(130,200,90,0.9)' : 'rgba(95,160,70,0.72)';
      ctx.font=`bold ${lbl.length===1?16:12}px sans-serif`;
      ctx.textAlign='center'; ctx.textBaseline='top';
      ctx.fillText(lbl, p.x, p.y+8);
    }

    // ── HUD
    const fsCityEl = document.getElementById('sm-fs-city') as HTMLSelectElement;
    const cityName = fsCityEl?.options[fsCityEl.selectedIndex]?.text ?? '';
    const dateStr = date.toLocaleDateString('fr-FR',{day:'numeric',month:'long',year:'numeric'})
      + '  ·  ' + date.toLocaleTimeString('fr-FR',{hour:'2-digit',minute:'2-digit'});
    const dirStr = `Az ${Math.round(((fsAzC%360)+360)%360)}°  ·  Alt ${Math.round(fsAltC)}°  ·  FOV ${Math.round(fsFov)}°`;
    ctx.save();
    ctx.fillStyle='rgba(4,6,22,0.70)';
    (ctx as any).roundRect?.(16,16,340,90,10); ctx.fill();
    ctx.strokeStyle='rgba(90,120,220,0.18)'; ctx.lineWidth=1; ctx.stroke();
    ctx.fillStyle='rgba(210,220,255,0.92)'; ctx.font='bold 13px sans-serif';
    ctx.textAlign='left'; ctx.textBaseline='top'; ctx.fillText(dateStr,28,24);
    ctx.fillStyle='rgba(140,165,220,0.72)'; ctx.font='12px sans-serif'; ctx.fillText('📍 '+cityName,28,46);
    ctx.fillStyle='rgba(100,125,195,0.50)'; ctx.font='11px sans-serif'; ctx.fillText(dirStr,28,68);
    ctx.restore();
  }

  // ─── Plein écran — état et contrôles
  let fsOpen = false;
  let fsHideTimer: ReturnType<typeof setTimeout> | null = null;
  let fsDragging = false;
  let fsDragAz0 = 180, fsDragAlt0 = 30, fsDragX0 = 0, fsDragY0 = 0;
  let fsPinchDist0 = 0, fsFov0 = 90;

  // Copie les options de la ville dans le select FS au premier appel
  function syncFsCity() {
    const src = document.getElementById('sm-city') as HTMLSelectElement;
    const dst = document.getElementById('sm-fs-city') as HTMLSelectElement;
    if (dst.options.length > 0) return;
    Array.from(src.options).forEach(o => {
      const opt = new Option(o.text, o.value, o.defaultSelected, o.selected);
      dst.add(opt);
    });
  }

  function getFsParams(): { date: Date; lat: number; lon: number } {
    const dtInput = document.getElementById('sm-fs-datetime') as HTMLInputElement;
    const citySelect = document.getElementById('sm-fs-city') as HTMLSelectElement;
    const [lat, lon] = citySelect.value.split(',').map(Number);
    const date = dtInput.value ? new Date(dtInput.value) : new Date();
    return { date, lat, lon };
  }

  function redrawFs() {
    const fsCanvas = document.getElementById('sm-fs-canvas') as HTMLCanvasElement;
    const { date, lat, lon } = getFsParams();
    drawFullscreen(fsCanvas, date, lat, lon);
  }

  function showToolbar() {
    const tb = document.getElementById('sm-fs-toolbar')!;
    tb.classList.add('visible');
    if (fsHideTimer) clearTimeout(fsHideTimer);
    fsHideTimer = setTimeout(() => {
      if (document.activeElement !== fsSearchInput) tb.classList.remove('visible');
    }, 3000);
  }

  function openFullscreen() {
    syncFsCity();
    // Synchronise les valeurs depuis le formulaire principal
    const mainDt = document.getElementById('sm-datetime') as HTMLInputElement;
    const mainCity = document.getElementById('sm-city') as HTMLSelectElement;
    const fsDt = document.getElementById('sm-fs-datetime') as HTMLInputElement;
    const fsCity = document.getElementById('sm-fs-city') as HTMLSelectElement;
    fsDt.value = mainDt.value;
    fsCity.value = mainCity.value;

    const overlay = document.getElementById('sm-fullscreen')!;
    const fsCanvas = document.getElementById('sm-fs-canvas') as HTMLCanvasElement;
    fsCanvas.width = window.innerWidth;
    fsCanvas.height = window.innerHeight;
    overlay.classList.add('is-open');
    overlay.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    fsOpen = true;
    redrawFs();
    showToolbar();
  }

  function closeFullscreen() {
    // Répercute les valeurs FS → formulaire principal
    const mainDt = document.getElementById('sm-datetime') as HTMLInputElement;
    const mainCity = document.getElementById('sm-city') as HTMLSelectElement;
    const fsDt = document.getElementById('sm-fs-datetime') as HTMLInputElement;
    const fsCity = document.getElementById('sm-fs-city') as HTMLSelectElement;
    mainDt.value = fsDt.value;
    mainCity.value = fsCity.value;

    document.getElementById('sm-fullscreen')!.classList.remove('is-open');
    document.getElementById('sm-fullscreen')!.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    fsOpen = false;
    if (fsHideTimer) clearTimeout(fsHideTimer);
  }

  // Mouvement souris → affiche toolbar
  document.getElementById('sm-fullscreen')!.addEventListener('mousemove', () => {
    if (fsOpen) showToolbar();
  });

  // Changement de date/heure ou lieu → redessine
  document.getElementById('sm-fs-datetime')!.addEventListener('change', redrawFs);
  document.getElementById('sm-fs-city')!.addEventListener('change', redrawFs);

  // Boutons ±temps
  document.querySelectorAll('.fs-step-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const fsDt = document.getElementById('sm-fs-datetime') as HTMLInputElement;
      const step = parseInt((btn as HTMLElement).dataset.step ?? '0', 10);
      const current = fsDt.value ? new Date(fsDt.value) : new Date();
      current.setSeconds(current.getSeconds() + step);
      // Format datetime-local : YYYY-MM-DDTHH:MM
      const pad = (n: number) => String(n).padStart(2, '0');
      fsDt.value = `${current.getFullYear()}-${pad(current.getMonth()+1)}-${pad(current.getDate())}T${pad(current.getHours())}:${pad(current.getMinutes())}`;
      redrawFs();
    });
  });

  // Bouton Maintenant
  document.getElementById('sm-fs-now')!.addEventListener('click', () => {
    const fsDt = document.getElementById('sm-fs-datetime') as HTMLInputElement;
    const now = new Date();
    const pad = (n: number) => String(n).padStart(2, '0');
    fsDt.value = `${now.getFullYear()}-${pad(now.getMonth()+1)}-${pad(now.getDate())}T${pad(now.getHours())}:${pad(now.getMinutes())}`;
    redrawFs();
  });

  // Géolocalisation FS
  document.getElementById('sm-fs-geolocate')!.addEventListener('click', () => {
    if (!navigator.geolocation) return;
    navigator.geolocation.getCurrentPosition(pos => {
      const fsCity = document.getElementById('sm-fs-city') as HTMLSelectElement;
      const customVal = `${pos.coords.latitude.toFixed(4)},${pos.coords.longitude.toFixed(4)}`;
      // Ajoute ou réutilise une option "Ma position"
      let opt = Array.from(fsCity.options).find(o => o.text === 'Ma position');
      if (!opt) { opt = new Option('Ma position', customVal); fsCity.add(opt); }
      else opt.value = customVal;
      fsCity.value = customVal;
      redrawFs();
    });
  });

  // ── Recherche d'objets
  const fsSearchInput = document.getElementById('sm-fs-search') as HTMLInputElement;
  const fsSearchResults = document.getElementById('sm-fs-search-results')!;

  function buildSearchCatalog(): { label: string; ra: number; dec: number }[] {
    const items: { label: string; ra: number; dec: number }[] = [];
    for (const s of STARS) {
      if (s[4]) items.push({ label: s[4], ra: s[0] * 15, dec: s[1] });
    }
    for (const d of DSO) {
      items.push({ label: d[2], ra: d[0] * 15, dec: d[1] });
    }
    items.push({ label: 'Soleil', ra: -1, dec: -1 });
    items.push({ label: 'Lune', ra: -2, dec: -2 });
    for (const [pname, [, plabel]] of Object.entries(PLANET_DISPLAY)) {
      items.push({ label: plabel, ra: -10, dec: Number(Object.keys(PLANET_DISPLAY).indexOf(pname)) });
    }
    return items;
  }

  const searchCatalog = buildSearchCatalog();

  function pointCameraAt(ra: number, dec: number) {
    const { date, lat, lon } = getFsParams();
    const jd = julianDate(date);
    let aa: { alt: number; az: number };
    if (ra === -1) {
      aa = toAltAz(sunRaDec(jd).ra, sunRaDec(jd).dec, lat, lon, jd);
    } else if (ra === -2) {
      aa = toAltAz(moonRaDec(jd).ra, moonRaDec(jd).dec, lat, lon, jd);
    } else if (ra === -10) {
      const pnames = Object.keys(PLANET_DISPLAY);
      const pos = planetRaDec(pnames[dec], jd);
      aa = toAltAz(pos.ra, pos.dec, lat, lon, jd);
    } else {
      aa = toAltAz(ra, dec, lat, lon, jd);
    }
    fsAzC = (aa.az + 360) % 360;
    fsAltC = Math.max(-89, Math.min(89, aa.alt));
    redrawFs();
  }

  fsSearchInput.addEventListener('input', () => {
    const q = fsSearchInput.value.trim().toLowerCase();
    fsSearchResults.innerHTML = '';
    if (q.length < 2) { fsSearchResults.style.display = 'none'; return; }
    const matches = searchCatalog.filter(o => o.label.toLowerCase().includes(q)).slice(0, 8);
    if (!matches.length) { fsSearchResults.style.display = 'none'; return; }
    for (const m of matches) {
      const li = document.createElement('li');
      li.textContent = m.label;
      li.addEventListener('mousedown', (e) => {
        e.preventDefault();
        fsSearchInput.value = m.label;
        fsSearchResults.style.display = 'none';
        pointCameraAt(m.ra, m.dec);
      });
      fsSearchResults.appendChild(li);
    }
    fsSearchResults.style.display = 'block';
  });

  fsSearchInput.addEventListener('blur', () => {
    setTimeout(() => { fsSearchResults.style.display = 'none'; }, 150);
  });

  fsSearchInput.addEventListener('keydown', (e) => {
    showToolbar(); // empêche la toolbar de se cacher pendant la saisie
    e.stopPropagation(); // empêche les raccourcis clavier (flèches, +/-…) de se déclencher
    if (e.key === 'Enter') {
      const first = fsSearchResults.querySelector('li');
      if (first) (first as HTMLElement).dispatchEvent(new MouseEvent('mousedown'));
    }
    if (e.key === 'Escape') { fsSearchResults.style.display = 'none'; fsSearchInput.blur(); }
  });

  document.getElementById('starmap-canvas')!.addEventListener('click', openFullscreen);
  document.getElementById('sm-fs-close')!.addEventListener('click', closeFullscreen);

  // ── Clavier : flèches (pan) · +/- (zoom) · Échap (fermer)
  document.addEventListener('keydown', (e) => {
    if (!fsOpen) { if (e.key === 'Escape') closeFullscreen(); return; }
    const step = fsFov / 8;
    switch (e.key) {
      case 'ArrowLeft':  fsAzC = (fsAzC - step + 360) % 360; redrawFs(); e.preventDefault(); break;
      case 'ArrowRight': fsAzC = (fsAzC + step) % 360;       redrawFs(); e.preventDefault(); break;
      case 'ArrowUp':    fsAltC = Math.min(89, fsAltC + step); redrawFs(); e.preventDefault(); break;
      case 'ArrowDown':  fsAltC = Math.max(-89, fsAltC - step); redrawFs(); e.preventDefault(); break;
      case '+': case '=': fsFov = Math.max(10, fsFov * 0.85); redrawFs(); break;
      case '-': case '_': fsFov = Math.min(150, fsFov * 1.18); redrawFs(); break;
      case 'Escape': closeFullscreen(); break;
    }
  });

  // ── Souris : drag pour pivoter
  const fsOverlay = document.getElementById('sm-fullscreen')!;
  const fsCvs = document.getElementById('sm-fs-canvas') as HTMLCanvasElement;

  fsOverlay.addEventListener('mousedown', (e) => {
    const tgt = e.target as HTMLElement;
    // Ne pas lancer le drag si on clique sur la toolbar
    if (tgt.closest('#sm-fs-toolbar') || tgt.closest('#sm-fs-close')) return;
    fsDragging = true;
    fsDragX0 = e.clientX; fsDragY0 = e.clientY;
    fsDragAz0 = fsAzC; fsDragAlt0 = fsAltC;
    fsCvs.style.cursor = 'grabbing';
  });

  window.addEventListener('mousemove', (e) => {
    if (!fsDragging) return;
    const dx = e.clientX - fsDragX0;
    const dy = e.clientY - fsDragY0;
    const sens = fsFov / Math.min(window.innerWidth, window.innerHeight);
    fsAzC = (fsDragAz0 + dx * sens + 360) % 360;
    fsAltC = Math.max(-89, Math.min(89, fsDragAlt0 - dy * sens));
    redrawFs();
  });

  window.addEventListener('mouseup', () => {
    if (!fsDragging) return;
    fsDragging = false;
    fsCvs.style.cursor = 'grab';
  });

  // ── Molette : zoom
  fsOverlay.addEventListener('wheel', (e) => {
    if (!fsOpen) return;
    e.preventDefault();
    const factor = e.deltaY > 0 ? 1.12 : 0.89;
    fsFov = Math.max(10, Math.min(150, fsFov * factor));
    redrawFs();
  }, { passive: false });

  // ── Tactile : drag + pinch
  let fsLastTouches: Touch[] = [];
  fsCvs.addEventListener('touchstart', (e) => {
    e.preventDefault();
    fsLastTouches = Array.from(e.touches);
    if (e.touches.length === 1) {
      fsDragX0 = e.touches[0].clientX; fsDragY0 = e.touches[0].clientY;
      fsDragAz0 = fsAzC; fsDragAlt0 = fsAltC;
    } else if (e.touches.length === 2) {
      fsPinchDist0 = Math.hypot(e.touches[0].clientX - e.touches[1].clientX, e.touches[0].clientY - e.touches[1].clientY);
      fsFov0 = fsFov;
    }
  }, { passive: false });

  fsCvs.addEventListener('touchmove', (e) => {
    e.preventDefault();
    if (e.touches.length === 1) {
      const dx = e.touches[0].clientX - fsDragX0;
      const dy = e.touches[0].clientY - fsDragY0;
      const sens = fsFov / Math.min(window.innerWidth, window.innerHeight);
      fsAzC = (fsDragAz0 + dx * sens + 360) % 360;
      fsAltC = Math.max(-89, Math.min(89, fsDragAlt0 - dy * sens));
      redrawFs();
    } else if (e.touches.length === 2) {
      const dist = Math.hypot(e.touches[0].clientX - e.touches[1].clientX, e.touches[0].clientY - e.touches[1].clientY);
      fsFov = Math.max(10, Math.min(150, fsFov0 * (fsPinchDist0 / dist)));
      redrawFs();
    }
  }, { passive: false });

  window.addEventListener('resize', () => {
    if (!fsOpen) return;
    const fsCanvas = document.getElementById('sm-fs-canvas') as HTMLCanvasElement;
    fsCanvas.width = window.innerWidth;
    fsCanvas.height = window.innerHeight;
    redrawFs();
  });

  // ── Fullscreen : hover + click sur les objets
  const fsTip = document.getElementById('sm-fs-tooltip')!;
  let fsDragMoved = false;

  fsCvs.addEventListener('mousemove', (e) => {
    if (fsDragging) { fsDragMoved = true; fsTip.style.display = 'none'; return; }
    const rect = fsCvs.getBoundingClientRect();
    const mx = e.clientX - rect.left;
    const my = e.clientY - rect.top;
    let found: FsCelPos | null = null;
    for (const obj of fsCelestialPositions) {
      if (Math.hypot(mx - obj.x, my - obj.y) < obj.r) { found = obj; break; }
    }
    if (found) {
      fsCvs.style.cursor = 'pointer';
      fsTip.innerHTML = `<strong>${found.name}</strong><br>${found.desc}`;
      fsTip.style.display = 'block';
      const tipX = Math.min(e.clientX - rect.left + 16, rect.width - 230);
      const tipY = Math.max(e.clientY - rect.top - 10, 10);
      fsTip.style.left = tipX + 'px';
      fsTip.style.top  = tipY + 'px';
    } else {
      fsCvs.style.cursor = fsDragging ? 'grabbing' : 'grab';
      fsTip.style.display = 'none';
    }
  });

  fsCvs.addEventListener('mouseleave', () => { fsTip.style.display = 'none'; });

  fsOverlay.addEventListener('mousedown', () => { fsDragMoved = false; });

  // Hover tooltip for DSOs
  const canvas2 = document.getElementById('starmap-canvas') as HTMLCanvasElement;
  const tooltip = document.getElementById('sm-tooltip')!;
  canvas2.addEventListener('mousemove', (e) => {
    const rect = canvas2.getBoundingClientRect();
    const scaleX = canvas2.width / rect.width;
    const scaleY = canvas2.height / rect.height;
    const mx = (e.clientX - rect.left) * scaleX;
    const my = (e.clientY - rect.top) * scaleY;
    let found = false;
    for (const d of dsoPositions) {
      const dist = Math.hypot(mx - d.x, my - d.y);
      if (dist < 18) {
        tooltip.innerHTML = `<strong>${d.name}</strong><br>${d.desc}`;
        tooltip.style.display = 'block';
        tooltip.style.left = (e.clientX - rect.left + 14) + 'px';
        tooltip.style.top  = (e.clientY - rect.top  - 10) + 'px';
        found = true;
        break;
      }
    }
    if (!found) tooltip.style.display = 'none';
  });
  canvas2.addEventListener('mouseleave', () => { tooltip.style.display = 'none'; });

  // Initial draw
  const { date, lat, lon } = getParams();
  draw(date, lat, lon);
  updateInfo(date, lat, lon);
  populateSidebar();
});
</script>

<style>
  .starmap-section {
    position: relative;
    padding: 5rem var(--grid-gutter);
    background: var(--gray-900);
  }

  .starmap-section::before {
    --hero-bg: var(--bg-image-subtle-2);
    content: '';
    position: absolute;
    pointer-events: none;
    left: 50%;
    width: 100vw;
    aspect-ratio: calc(2.25 / var(--bg-scale));
    top: 0;
    transform: translateY(-75%) translateX(-50%);
    background:
      url('/assets/backgrounds/noise.png') top center/220px repeat,
      var(--hero-bg) center center / var(--bg-gradient-size) no-repeat,
      var(--gray-900);
    background-blend-mode: overlay, normal, normal, normal;
    mix-blend-mode: var(--bg-blend-mode);
    z-index: -1;
  }

  .section-header {
    text-align: center;
    max-width: 50ch;
    margin: 0 auto;
    color: var(--gray-300);
  }

  .section-header h2 {
    font-size: var(--text-2xl);
    color: var(--gray-0);
    margin-bottom: 0.5rem;
  }

  .starmap-controls {
    max-width: 60rem;
    margin: 0 auto;
  }

  .control-row {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    align-items: flex-end;
  }

  .control-group {
    display: flex;
