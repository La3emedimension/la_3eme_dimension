---
interface Props {
  title?: string;
  description?: string;
}
const { title = "Observe ce soir", description = "Génère ta carte du ciel personnalisée pour cette nuit." } = Astro.props;
---

<div class="starmap-section">
  <div class="wrapper stack gap-8">
    <header class="section-header stack gap-2 lg:gap-4">
      <h2>{title}</h2>
      <p>{description}</p>
    </header>

    <div class="starmap-controls">
      <div class="control-row">
        <div class="control-group">
          <label for="sm-datetime">Date et heure</label>
          <input type="datetime-local" id="sm-datetime" />
        </div>
        <div class="control-group">
          <label for="sm-city">Lieu</label>
          <div class="city-row">
            <select id="sm-city">
              <option value="48.8566,2.3522">Paris</option>
              <option value="45.7640,4.8357">Lyon</option>
              <option value="43.2965,5.3813">Marseille</option>
              <option value="43.6047,1.4442" selected>Toulouse</option>
              <option value="44.8378,-0.5792">Bordeaux</option>
              <option value="47.2184,-1.5536">Nantes</option>
              <option value="48.5734,7.7521">Strasbourg</option>
              <option value="43.6112,3.8767">Montpellier</option>
              <option value="43.7102,7.2620">Nice</option>
              <option value="50.6292,3.0573">Lille</option>
              <option value="45.1885,5.7245">Grenoble</option>
              <option value="48.1173,-1.6778">Rennes</option>
              <option value="49.2583,4.0317">Reims</option>
              <option value="43.1242,5.9280">Toulon</option>
              <option value="45.7797,3.0863">Clermont-Ferrand</option>
              <option value="47.3220,5.0415">Dijon</option>
              <option value="48.3904,-4.4861">Brest</option>
              <option value="42.6886,2.8948">Perpignan</option>
              <option value="49.4432,1.0993">Rouen</option>
              <option value="49.1193,6.1757">Metz</option>
            </select>
            <button id="sm-geolocate" title="Utiliser ma position GPS">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="3"/><path d="M12 2v3M12 19v3M2 12h3M19 12h3"/>
                <circle cx="12" cy="12" r="8" opacity="0.3"/>
              </svg>
              Ma position
            </button>
          </div>
        </div>
        <button id="sm-generate" class="generate-btn">Générer la carte</button>
      </div>
    </div>

    <div class="canvas-wrapper">
      <div id="sm-detail" class="sm-detail-left"></div>

      <div class="canvas-container">
        <canvas id="starmap-canvas" width="700" height="700" aria-label="Carte du ciel"></canvas>
        <div id="sm-tooltip" class="sm-tooltip"></div>
        <div class="sm-expand-hint">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="15 3 21 3 21 9"/><polyline points="9 21 3 21 3 15"/>
            <line x1="21" y1="3" x2="14" y2="10"/><line x1="3" y1="21" x2="10" y2="14"/>
          </svg>
          Plein écran
        </div>
      </div>

      <div class="sm-sidebar">
        <div class="sidebar-header">Objets visibles</div>
        <div id="sm-list" class="sidebar-list">
          <p class="sidebar-empty">Clique sur "Générer" pour voir les objets visibles.</p>
        </div>
      </div>
    </div>

    <div id="sm-info" class="sm-info"></div>

    <div class="dso-legend">
      <span class="legend-title">Objets visibles avec une 50/200</span>
      <span class="legend-item"><svg width="18" height="18" viewBox="0 0 18 18"><rect x="3" y="3" width="12" height="12" fill="none" stroke="#44ffcc" stroke-width="1.2" stroke-dasharray="2,2"/></svg>Nébuleuse</span>
      <span class="legend-item"><svg width="18" height="18" viewBox="0 0 18 18"><circle cx="9" cy="9" r="7" fill="none" stroke="#ffdd44" stroke-width="1.2" stroke-dasharray="2,2"/></svg>Amas ouvert</span>
      <span class="legend-item"><svg width="18" height="18" viewBox="0 0 18 18"><circle cx="9" cy="9" r="7" fill="none" stroke="#88ccff" stroke-width="1.2"/><line x1="2" y1="9" x2="16" y2="9" stroke="#88ccff" stroke-width="1.2"/><line x1="9" y1="2" x2="9" y2="16" stroke="#88ccff" stroke-width="1.2"/></svg>Amas globulaire</span>
      <span class="legend-item"><svg width="20" height="18" viewBox="0 0 20 18"><ellipse cx="10" cy="9" rx="9" ry="4" fill="none" stroke="#ff88cc" stroke-width="1.2"/></svg>Galaxie</span>
      <span class="legend-item"><svg width="18" height="18" viewBox="0 0 18 18"><circle cx="6" cy="9" r="4" fill="none" stroke="rgba(220,240,255,0.85)" stroke-width="1.2"/><circle cx="12" cy="9" r="4" fill="none" stroke="rgba(220,240,255,0.85)" stroke-width="1.2"/></svg>Étoile double</span>
    </div>

    <details class="sm-tuto">
      <summary class="sm-tuto-title">Comment lire la carte du ciel ?</summary>
      <div class="sm-tuto-body">
        <div class="tuto-grid">

          <div class="tuto-card">
            <div class="tuto-icon">🔵</div>
            <h4>Orientation de la carte</h4>
            <p>Le <strong>centre</strong> représente le point juste au-dessus de ta tête (le zénith). Le <strong>bord</strong> représente l'horizon. Plus un objet est proche du centre, plus il est haut dans le ciel.</p>
            <p>Les directions sont : <strong>N</strong> en haut, <strong>E</strong> à gauche, <strong>S</strong> en bas, <strong>O</strong> à droite — comme si tu regardais le ciel en te couchant sur le dos, la tête vers le Nord.</p>
          </div>

          <div class="tuto-card">
            <div class="tuto-icon">⭐</div>
            <h4>Les étoiles et constellations</h4>
            <p>Les points blancs sont les étoiles — plus ils sont gros, plus l'étoile est brillante. Les lignes bleues relient les étoiles pour former les <strong>constellations</strong>, comme Orion ou la Grande Ourse.</p>
            <p>Les couleurs indiquent la température : bleu = très chaud, blanc = chaud, jaune-orange = plus froid.</p>
          </div>

          <div class="tuto-card">
            <div class="tuto-icon">🔭</div>
            <h4>Les symboles d'objets</h4>
            <ul class="tuto-symbols">
              <li><span class="sym-neb">□ pointillé cyan</span> Nébuleuse — nuage de gaz</li>
              <li><span class="sym-oc">○ pointillé jaune</span> Amas ouvert — groupe d'étoiles</li>
              <li><span class="sym-gc">⊕ bleu clair</span> Amas globulaire — sphère d'étoiles</li>
              <li><span class="sym-gal">⬭ rose</span> Galaxie — système d'étoiles lointain</li>
              <li><span class="sym-db">◎ blanc</span> Étoile double — deux étoiles liées</li>
            </ul>
          </div>

          <div class="tuto-card">
            <div class="tuto-icon">🌙</div>
            <h4>Utiliser la carte avec ta Lumi</h4>
            <ol class="tuto-steps">
              <li>Génère la carte pour <strong>ce soir</strong> à ton lieu d'observation.</li>
              <li>Repère un objet dans la liste à droite — commence par la <strong>Lune</strong> ou une planète brillante.</li>
              <li>Oriente-toi avec une boussole ou en repérant l'Étoile Polaire (toujours au Nord).</li>
              <li>Pointe ta lunette dans la bonne direction et cherche l'objet dans le champ.</li>
              <li>Attends <strong>20 minutes dans le noir</strong> pour que tes yeux s'adaptent — tu verras beaucoup plus !</li>
            </ol>
          </div>

        </div>
      </div>
    </details>

    <div class="starmap-footer">
      <button id="sm-print-a4" class="download-btn">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 01-2-2v-5a2 2 0 012-2h16a2 2 0 012 2v5a2 2 0 01-2 2h-2"/><rect x="6" y="14" width="12" height="8"/>
        </svg>
        Imprimer A4 N&amp;B
      </button>
      <p class="starmap-note">N = Nord · E = Est · S = Sud · O = Ouest — vue depuis le sol, Nord en haut</p>
    </div>
  </div>
</div>

<!-- Overlay plein écran -->
<div id="sm-fullscreen" class="sm-fullscreen-overlay" aria-hidden="true">
  <canvas id="sm-fs-canvas" aria-label="Carte du ciel plein écran"></canvas>

  <!-- Toolbar Stellarium -->
  <div id="sm-fs-toolbar" class="sm-fs-toolbar">
    <div class="sm-fs-toolbar-inner">

      <div class="fs-ctrl-group">
        <label for="sm-fs-datetime">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
          </svg>
          Date &amp; heure
        </label>
        <input type="datetime-local" id="sm-fs-datetime" />
      </div>

      <div class="fs-ctrl-group">
        <label for="sm-fs-city">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="3"/><path d="M12 2v3M12 19v3M2 12h3M19 12h3"/>
          </svg>
          Lieu
        </label>
        <div class="fs-city-row">
          <select id="sm-fs-city"></select>
          <button id="sm-fs-geolocate" title="Ma position GPS">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="3"/><path d="M12 2v3M12 19v3M2 12h3M19 12h3"/>
              <circle cx="12" cy="12" r="8" opacity="0.35"/>
            </svg>
          </button>
        </div>
      </div>

      <button id="sm-fs-now" class="fs-btn">Maintenant</button>

      <div class="fs-time-nav">
        <button class="fs-step-btn" data-step="-3600">−1h</button>
        <button class="fs-step-btn" data-step="-600">−10m</button>
        <button class="fs-step-btn" data-step="600">+10m</button>
        <button class="fs-step-btn" data-step="3600">+1h</button>
        <button class="fs-step-btn" data-step="86400">+1j</button>
      </div>

      <div class="fs-ctrl-group fs-search-group">
        <label for="sm-fs-search">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
          </svg>
          Recherche
        </label>
        <div class="fs-search-wrap">
          <input type="text" id="sm-fs-search" placeholder="Étoile, planète, objet…" autocomplete="off" />
          <ul id="sm-fs-search-results" class="fs-search-results"></ul>
        </div>
      </div>

      <button id="sm-fs-close" class="sm-fs-close" aria-label="Fermer">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>

    </div>
  </div>

  <div id="sm-fs-tooltip" class="sm-fs-tooltip"></div>
  <p class="sm-fs-hint">Déplacez la souris pour afficher les contrôles · <kbd>Échap</kbd> pour fermer</p>
</div>

