---
import { getLocalizedCollection } from '../lib/collections';
import type { Locale } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

// Get all products (excluding drafts and specific products)
const allProducts = await getLocalizedCollection('products', locale);

const excludedProducts = ['bhh', 'seestar-accessoires', 'vis-collimation'];

const filteredProducts = allProducts.filter(p => {
  const productId = p.id.replace(`${locale}/`, '');
  return !p.data.draft && !excludedProducts.includes(productId);
});

// Sort products: smallest first, ert second, then others
const products = filteredProducts.sort((a, b) => {
  const aId = a.id.replace(`${locale}/`, '');
  const bId = b.id.replace(`${locale}/`, '');

  if (aId === 'lumi') return -1;
  if (bId === 'lumi') return 1;
  if (aId === 'smallest') return -1;
  if (bId === 'smallest') return 1;
  if (aId === 'picco') return -1;
  if (bId === 'picco') return 1;

  return 0;
});
---

<div class="product-carousel">
  <div class="carousel-container">
    {products.map((product, index) => {
      const heroSection = product.data.sections.find(s => s.type === 'hero');
      const heroData = heroSection?.data;
      const carouselImage = product.data.carouselImage ?? heroData?.heroImage;
      const carouselVideoSrc = product.data.carouselVideoSrc;
      const carouselVideo = product.data.carouselVideo;

      const productSlug = product.id.replace(`${locale}/`, '');
      const isLumi = productSlug === 'lumi';
      const isSmallest = productSlug === 'smallest';

      const productInfoContent = (
        <div class="product-info">
          <h3>{!isLumi && !isSmallest && (heroData?.title || product.id)}</h3>
          {isLumi && <img src="/assets/logolumi.png" alt="Lumi" class="lumi-logo-carousel" />}
          {isSmallest && <img src="/assets/smallestlogo.png" alt="Smallest" class="smallest-logo-carousel" />}
          {isSmallest && <p class="carousel-subtitle">Le Télescope de 150mm le plus transportable au monde</p>}
          {heroData?.tagline && <p class={isLumi ? 'carousel-subtitle' : 'carousel-text'}>{heroData.tagline}</p>}
          {isLumi && <p class="carousel-text">« La science est une chose trop importante pour être laissée entre les mains des seuls savants. » — Carl Sagan</p>}
        </div>
      );

      if (carouselVideoSrc) {
        return (
          <div class="carousel-slide" data-index={index} data-video="true">
            <div class="video-fill">
              <video autoplay muted playsinline>
                <source src={carouselVideoSrc} type="video/webm" />
              </video>
            </div>
            <a href={`/product/${productSlug}`} class="slide-link-overlay"></a>
            {productInfoContent}
          </div>
        );
      }

      if (carouselVideo) {
        return (
          <div class="carousel-slide" data-index={index} data-video="true">
            <div class="video-fill">
              <iframe
                src={`https://www.youtube-nocookie.com/embed/${carouselVideo}?autoplay=1&mute=1&loop=1&playlist=${carouselVideo}&controls=0&rel=0&playsinline=1`}
                title={heroData?.title || 'Vidéo produit'}
                allow="autoplay; accelerometer; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
              ></iframe>
            </div>
            <a href={`/product/${productSlug}`} class="slide-link-overlay"></a>
            {productInfoContent}
          </div>
        );
      }

      return (
        <div class="carousel-slide" data-index={index}>
          {carouselImage?.src && (
            <img
              src={carouselImage.src}
              alt={carouselImage.alt || heroData?.title}
              loading="lazy"
              class={`slide-img${carouselImage.zoom ? ' zoomed' : ''}`}
              style={[carouselImage.zoom ? `--img-zoom: ${carouselImage.zoom}` : '', carouselImage.position ? `object-position: ${carouselImage.position}` : ''].filter(Boolean).join('; ')}
            />
          )}
          <a href={`/product/${productSlug}`} class="slide-link-overlay"></a>
          {productInfoContent}
        </div>
      );
    })}
  </div>

  <div class="carousel-dots">
    {products.map((_, index) => (
      <button class={`dot ${index === 0 ? 'active' : ''}`} data-index={index} aria-label={`Slide ${index + 1}`}></button>
    ))}
  </div>
</div>

<style>
  .product-carousel {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    border-radius: 1rem;
  }

  .carousel-container {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .carousel-slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.5s ease-in-out;
    pointer-events: none;
  }

  .carousel-slide.active {
    opacity: 1;
    pointer-events: auto;
  }

  .slide-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 60%;
  }

  .slide-img.zoomed {
    transform: scale(var(--img-zoom, 1.25));
  }

  .product-info {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1.5rem;
    background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, transparent 100%);
    color: white;
  }

  .lumi-logo-carousel,
  .smallest-logo-carousel {
    display: block;
    max-height: 60px;
    width: auto !important;
    height: auto !important;
    object-fit: unset !important;
    margin-bottom: 0.25rem;
  }

  @media (min-width: 50em) {
    .lumi-logo-carousel,
    .smallest-logo-carousel {
      max-height: 200px;
      transform: translateY(3.5rem);
    }
  }

  .product-info h3 {
    margin: 0;
    font-size: var(--text-xl);
    font-weight: 600;
    color: white;
  }

  .carousel-text {
    display: none;
  }

  @media (min-width: 50em) {
    .carousel-text {
      display: block;
      margin: 0.25rem 0 0 0;
      font-size: 0.875rem;
      font-style: italic;
      opacity: 0.9;
      color: white;
      line-height: 1.4;
    }
  }

  .carousel-subtitle {
    margin: 0.25rem 0 0 0;
    font-size: 1.05rem;
    font-style: normal;
    font-weight: 700;
    opacity: 0.9;
    color: white;
    line-height: 1.4;
  }

  @media (min-width: 50em) {
    .carousel-text,
    .carousel-subtitle {
      transform: translateY(-0.4rem);
    }
  }

  /* Video slide */
  .video-fill {
    position: absolute;
    inset: 0;
    overflow: hidden;
    background: #000;
  }

  .video-fill video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    pointer-events: none;
  }

  .video-fill iframe {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 100%;
    aspect-ratio: 9 / 16;
    min-height: 100%;
    border: none;
    pointer-events: none;
  }

  .slide-link-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .carousel-slide[data-video] .product-info {
    position: absolute;
    z-index: 2;
  }

  .carousel-dots {
    position: absolute;
    bottom: 1rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 0.5rem;
    z-index: 10;
  }

  .dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.5);
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .dot.active {
    background: white;
    width: 1.5rem;
    border-radius: 0.25rem;
  }

  @media (min-width: 50em) {
    .product-info h3 {
      font-size: var(--text-2xl);
    }

    .product-info .tagline {
      font-size: var(--text-md);
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const carousel = document.querySelector('.product-carousel');
    if (!carousel) return;

    const slides = carousel.querySelectorAll('.carousel-slide');
    const dots = carousel.querySelectorAll('.dot');
    let currentIndex = 0;
    let autoInterval: ReturnType<typeof setInterval> | null = null;

    function isVideoSlide(index: number) {
      return (slides[index] as HTMLElement)?.dataset.video === 'true';
    }

    function showSlide(index: number) {
      slides.forEach((slide, i) => slide.classList.toggle('active', i === index));
      dots.forEach((dot, i) => dot.classList.toggle('active', i === index));
      // Pause auto-advance sur les slides vidéo et relancer la vidéo
      if (isVideoSlide(index)) {
        if (autoInterval) clearInterval(autoInterval);
        autoInterval = null;
        const video = (slides[index] as HTMLElement).querySelector('video');
        if (video) {
          video.currentTime = 0;
          video.play();
        }
      }
    }

    function nextSlide() {
      currentIndex = (currentIndex + 1) % slides.length;
      showSlide(currentIndex);
    }

    function startAuto() {
      if (autoInterval) clearInterval(autoInterval);
      if (!isVideoSlide(currentIndex)) {
        autoInterval = setInterval(nextSlide, 5000);
      }
    }

    // Dot click handlers — restart auto-advance after 8s (sauf sur slide vidéo)
    dots.forEach((dot, index) => {
      dot.addEventListener('click', () => {
        currentIndex = index;
        showSlide(currentIndex);
        if (autoInterval) clearInterval(autoInterval);
        if (!isVideoSlide(currentIndex)) {
          autoInterval = setTimeout(startAuto, 8000) as unknown as ReturnType<typeof setInterval>;
        }
      });
    });

    // Swipe / touch support
    const container = carousel.querySelector('.carousel-container') as HTMLElement;
    let touchStartX = 0;
    let touchStartY = 0;

    container.addEventListener('touchstart', (e: TouchEvent) => {
      touchStartX = e.touches[0].clientX;
      touchStartY = e.touches[0].clientY;
    }, { passive: true });

    container.addEventListener('touchend', (e: TouchEvent) => {
      const dx = e.changedTouches[0].clientX - touchStartX;
      const dy = e.changedTouches[0].clientY - touchStartY;
      // Only trigger if horizontal swipe dominates
      if (Math.abs(dx) > 40 && Math.abs(dx) > Math.abs(dy)) {
        currentIndex = dx < 0
          ? (currentIndex + 1) % slides.length
          : (currentIndex - 1 + slides.length) % slides.length;
        showSlide(currentIndex);
        startAuto();
      }
    }, { passive: true });

    // Avancer au slide suivant à la fin de chaque vidéo
    slides.forEach((slide) => {
      const video = slide.querySelector('video');
      if (video) {
        let advanced = false;

        function advanceFromVideo() {
          if (advanced) return;
          advanced = true;
          currentIndex = (currentIndex + 1) % slides.length;
          showSlide(currentIndex);
          startAuto();
        }

        // Méthode principale
        video.addEventListener('ended', advanceFromVideo);

        // Filet de sécurité : avance si on est à moins de 0.3s de la fin
        video.addEventListener('timeupdate', () => {
          if (video.duration && video.currentTime >= video.duration - 0.3) {
            advanceFromVideo();
          }
        });

        // Réinitialise le flag quand la vidéo repart depuis le début
        video.addEventListener('play', () => {
          if (video.currentTime < 0.5) advanced = false;
        });
      }
    });

    showSlide(0);
    startAuto();
  });
</script>
