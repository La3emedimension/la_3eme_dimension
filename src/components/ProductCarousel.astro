---
import { getLocalizedCollection } from '../lib/collections';
import type { Locale } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

// Get all products (excluding drafts and specific products)
const allProducts = await getLocalizedCollection('products', locale);

const excludedProducts = ['bhh', 'seestar-accessoires', 'vis-collimation'];

const filteredProducts = allProducts.filter(p => {
  const productId = p.id.replace(`${locale}/`, '');
  return !p.data.draft && !excludedProducts.includes(productId);
});

// Sort products: smallest first, ert second, then others
const products = filteredProducts.sort((a, b) => {
  const aId = a.id.replace(`${locale}/`, '');
  const bId = b.id.replace(`${locale}/`, '');

  if (aId === 'lumi') return -1;
  if (bId === 'lumi') return 1;
  if (aId === 'smallest') return -1;
  if (bId === 'smallest') return 1;

  return 0;
});
---

<div class="product-carousel">
  <div class="carousel-container">
    {products.map((product, index) => {
      const heroSection = product.data.sections.find(s => s.type === 'hero');
      const heroData = heroSection?.data;
      const carouselImage = product.data.carouselImage ?? heroData?.heroImage;

      const productSlug = product.id.replace(`${locale}/`, '');
      const isLumi = productSlug === 'lumi';
      const isSmallest = productSlug === 'smallest';

      return (
        <div class="carousel-slide" data-index={index}>
          <a href={`/product/${productSlug}`} class="product-card">
            {carouselImage?.src && (
              <img
                src={carouselImage.src}
                alt={carouselImage.alt || heroData?.title}
                loading="lazy"
                style={[carouselImage.zoom ? `--img-zoom: ${carouselImage.zoom}` : '', carouselImage.position ? `object-position: ${carouselImage.position}` : ''].filter(Boolean).join('; ')}
                class={carouselImage.zoom ? 'zoomed' : ''}
              />
            )}
            <div class="product-info">
              <h3>
                {!isLumi && !isSmallest && (heroData?.title || product.id)}
              </h3>
              {isLumi && (
                <img src="/assets/logolumi.png" alt="Lumi" class="lumi-logo-carousel" />
              )}
              {isSmallest && (
                <img src="/assets/smallestlogo.png" alt="Smallest" class="smallest-logo-carousel" />
              )}
              {isSmallest && (
                <p class="smallest-subtitle">Le Télescope de 150 le plus transportable au monde</p>
              )}
              {heroData?.tagline && <p class={`tagline${isLumi ? ' lumi-tagline' : ''}`}>{heroData.tagline}</p>}
              {isLumi && (
                <p class="sagan-quote">« La science est une chose trop importante pour être laissée entre les mains des seuls savants. »<br/><span class="sagan-author">— Carl Sagan</span></p>
              )}
            </div>
          </a>
        </div>
      );
    })}
  </div>

  <div class="carousel-dots">
    {products.map((_, index) => (
      <button class={`dot ${index === 0 ? 'active' : ''}`} data-index={index} aria-label={`Slide ${index + 1}`}></button>
    ))}
  </div>
</div>

<style>
  .product-carousel {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    border-radius: 1rem;
  }

  .carousel-container {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .carousel-slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.5s ease-in-out;
    pointer-events: none;
  }

  .carousel-slide.active {
    opacity: 1;
    pointer-events: auto;
  }

  .product-card {
    display: block;
    width: 100%;
    height: 100%;
    position: relative;
    text-decoration: none;
    overflow: hidden;
  }

  .product-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 60%;
    transition: transform 0.3s ease;
  }

  .product-card img.zoomed {
    transform: scale(var(--img-zoom, 1.25));
  }

  .product-card:hover img {
    transform: scale(1.05);
  }

  .product-card:hover img.zoomed {
    transform: scale(calc(var(--img-zoom, 1.25) + 0.05));
  }

  .product-info {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1.5rem;
    background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, transparent 100%);
    color: white;
  }

  .lumi-logo-carousel {
    display: block;
    max-height: 200px;
    width: auto !important;
    height: auto !important;
    object-fit: unset !important;
    margin-bottom: 0.5rem;
    transform: translateY(3.5rem);
  }

  .smallest-logo-carousel {
    display: block;
    max-height: 200px;
    width: auto !important;
    height: auto !important;
    object-fit: unset !important;
    margin-bottom: 0.5rem;
    transform: translateY(3.5rem);
  }

  .product-info h3 {
    margin: 0;
    font-size: var(--text-xl);
    font-weight: 600;
    color: white;
  }

  .product-info .tagline {
    margin: 0.25rem 0 0 0;
    font-size: var(--text-sm);
    opacity: 0.9;
    color: white;
    font-style: italic;
  }

  .product-info .lumi-tagline {
    transform: translateY(-1rem);
  }

  .smallest-subtitle {
    margin: 0.25rem 0 0 0;
    font-size: var(--text-sm);
    opacity: 0.9;
    color: white;
    font-style: italic;
  }

  .sagan-quote {
    margin: 0.5rem 0 0 0;
    transform: translateY(-1rem);
    font-size: var(--text-xs, 0.75rem);
    font-style: italic;
    opacity: 0.8;
    color: white;
    line-height: 1.4;
  }

  .sagan-author {
    font-style: normal;
    opacity: 0.7;
    font-size: 0.7em;
  }

  .carousel-dots {
    position: absolute;
    bottom: 1rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 0.5rem;
    z-index: 10;
  }

  .dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.5);
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .dot.active {
    background: white;
    width: 1.5rem;
    border-radius: 0.25rem;
  }

  @media (min-width: 50em) {
    .product-info h3 {
      font-size: var(--text-2xl);
    }

    .product-info .tagline {
      font-size: var(--text-md);
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const carousel = document.querySelector('.product-carousel');
    if (!carousel) return;

    const slides = carousel.querySelectorAll('.carousel-slide');
    const dots = carousel.querySelectorAll('.dot');
    let currentIndex = 0;

    function showSlide(index: number) {
      slides.forEach((slide, i) => {
        slide.classList.toggle('active', i === index);
      });
      dots.forEach((dot, i) => {
        dot.classList.toggle('active', i === index);
      });
    }

    function nextSlide() {
      currentIndex = (currentIndex + 1) % slides.length;
      showSlide(currentIndex);
    }

    // Auto-advance every 5 seconds
    const interval = setInterval(nextSlide, 5000);

    // Dot click handlers
    dots.forEach((dot, index) => {
      dot.addEventListener('click', () => {
        currentIndex = index;
        showSlide(currentIndex);
        clearInterval(interval);
      });
    });

    // Initialize first slide
    showSlide(0);
  });
</script>
