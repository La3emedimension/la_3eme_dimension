---
import { getCollection } from 'astro:content';
import ProductLayout from '../../../layouts/ProductLayout.astro';
import SmallestOverview from '../../../components/SmallestOverview.astro';
import VideoGrid from '../../../components/VideoGrid.astro';
import SmallestSocialProof from '../../../components/SmallestSocialProof.astro';
import SmallestLearnMore from '../../../components/SmallestLearnMore.astro';
import CommunityMap from '../../../components/CommunityMap.astro';
import CommunitySection from '../../../components/CommunitySection.astro';
import ClefEtoilesSection from '../../../components/ClefEtoilesSection.astro';
import { type Locale } from '../../../i18n';
import { getSlugWithoutLocale } from '../../../lib/collections';

const locale: Locale = 'en';

export async function getStaticPaths() {
  const products = await getCollection('products');
  return products
    .filter(product => product.id.startsWith('en/'))
    .filter(({ data }) => import.meta.env.DEV || !data.draft)
    .map((product) => ({
      params: { slug: product.id.replace('en/', '').replace(/\.json$/, '') },
      props: { product },
    }));
}

const { product } = Astro.props;
const productConfig = product.data;
const productSlug = getSlugWithoutLocale(product.id, locale);

const customSections = [];

if (productSlug === 'smallest') {
  customSections.push({ type: 'custom', customComponent: SmallestOverview, data: {} });
  customSections.push({ type: 'custom', customComponent: SmallestSocialProof, data: {} });
  customSections.push({ type: 'custom', customComponent: SmallestLearnMore, data: {} });
}

const allSections = [...productConfig.sections];

allSections.forEach(section => {
  if (section.id === 'section-community-map' && section.type === 'custom') {
    section.customComponent = CommunityMap;
  }
  if (section.id === 'section-video-grid' && section.type === 'custom') {
    section.customComponent = VideoGrid;
  }
  if (section.id === 'section-community' && section.type === 'custom') {
    section.customComponent = CommunitySection;
  }
  if (section.id === 'section-clef-etoiles' && section.type === 'custom') {
    section.customComponent = ClefEtoilesSection;
  }
});

if (productSlug === 'smallest') {
  const videoGridIndex = allSections.findIndex(s => s.id === 'section-video-grid');
  const lastVideoIndex = videoGridIndex !== -1 ? videoGridIndex : allSections.reduce((last, s, i) => s.type === 'video' ? i : last, -1);
  if (lastVideoIndex !== -1) {
    allSections.splice(lastVideoIndex + 1, 0, customSections[0]);
  }
  const pricingIndex = allSections.findIndex(s => s.type === 'pricing');
  if (pricingIndex !== -1) {
    allSections.splice(pricingIndex + 1, 0, ...customSections.slice(1));
  }
}

const finalConfig = {
  ...productConfig,
  sections: allSections,
  locale
};
---

<ProductLayout {...finalConfig} />

<style is:global>
  /* ===== LUMI — section colors: pink, blue, yellow ===== */

  /* BLUE (#5B9BD5) */
  #section-video-2 .video-showcase,
  #section-video-5 .video-showcase,
  #section-reviews .reviews-section {
    background: #5B9BD5 !important;
  }

  /* YELLOW (#FFD700) */
  #section-video-3 .video-showcase,
  #section-specs .specs-section,
  #section-pricing .pricing-section,
  #section-features .features-section {
    background: #FFD700 !important;
  }

  /* PINK (#FF69B4) */
  #section-video-4 .video-showcase,
  #section-clef-etoiles .clef-etoiles-section {
    background: #FF69B4 !important;
  }
  #section-filter .hero-product {
    background: linear-gradient(135deg, #FF69B4 0%, #ff4da6 100%) !important;
  }

  #section-specs .specs-table {
    background: #ffffff !important;
  }
  #section-reviews .review-card {
    background: #ffffff !important;
  }

  /* Dark mode */
  :root.theme-dark #section-video-2 .video-showcase,
  :root.theme-dark #section-video-5 .video-showcase,
  :root.theme-dark #section-reviews .reviews-section {
    background: #2a6aa0 !important;
  }

  :root.theme-dark #section-video-3 .video-showcase,
  :root.theme-dark #section-specs .specs-section,
  :root.theme-dark #section-pricing .pricing-section,
  :root.theme-dark #section-features .features-section {
    background: #a08000 !important;
  }

  :root.theme-dark #section-video-4 .video-showcase,
  :root.theme-dark #section-clef-etoiles .clef-etoiles-section {
    background: #b0006e !important;
  }
  :root.theme-dark #section-filter .hero-product {
    background: linear-gradient(135deg, #b0006e 0%, #cc0080 100%) !important;
  }

  :root.theme-dark #section-specs .specs-table {
    background: #7a6200 !important;
  }
  :root.theme-dark #section-reviews .review-card {
    background: #1e5280 !important;
  }
</style>
